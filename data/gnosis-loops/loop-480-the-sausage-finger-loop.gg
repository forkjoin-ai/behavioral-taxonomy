// Topology
(loop_480_start)-[:PROCESS]->(loop_480_given_gate)
(loop_480_given_gate)-[:PROCESS { case: "ok" }]->(loop_480_when_gate)
(loop_480_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_480_inactive)
(loop_480_when_gate)-[:PROCESS { case: "ok" }]->(loop_480_context)
(loop_480_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_480_inactive)
(loop_480_context)-[:FORK { strategy: "behavior-branches" }]->(loop_480_context_branch | loop_480_then_branch | loop_480_operator_branch | loop_480_result_branch | loop_480_taxonomy_branch | loop_480_intervention_recognize | loop_480_intervention_interdict | loop_480_intervention_minimize)
(loop_480_context_branch | loop_480_then_branch | loop_480_operator_branch | loop_480_result_branch | loop_480_taxonomy_branch | loop_480_intervention_recognize | loop_480_intervention_interdict | loop_480_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_480_verdict)
(loop_480_inactive)-[:PROCESS]->(loop_480_sink)
