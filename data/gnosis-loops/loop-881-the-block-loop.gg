(loop_881_inactive: BehaviorTerminal { loopId: 881, loopName: 'The%20Block%20Loop' })
(loop_881_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
