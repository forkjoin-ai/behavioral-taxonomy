// Topology
(loop_881_start)-[:PROCESS]->(loop_881_given_gate)
(loop_881_given_gate)-[:PROCESS { case: "ok" }]->(loop_881_when_gate)
(loop_881_given_gate)-[:PROCESS { case: "err" }]->(loop_881_inactive)
(loop_881_when_gate)-[:PROCESS { case: "ok" }]->(loop_881_context)
(loop_881_when_gate)-[:PROCESS { case: "err" }]->(loop_881_inactive)
(loop_881_context)-[:FORK { strategy: "behavior-branches" }]->(loop_881_context_branch | loop_881_then_branch | loop_881_operator_branch | loop_881_result_branch | loop_881_taxonomy_branch | loop_881_intervention_recognize | loop_881_intervention_interdict | loop_881_intervention_minimize)
(loop_881_context_branch | loop_881_then_branch | loop_881_operator_branch | loop_881_result_branch | loop_881_taxonomy_branch | loop_881_intervention_recognize | loop_881_intervention_interdict | loop_881_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_881_verdict)
(loop_881_inactive)-[:PROCESS]->(loop_881_sink)
(loop_881_verdict)-[:PROCESS]->(loop_881_sink)
(loop_881_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_881_then_branch)
