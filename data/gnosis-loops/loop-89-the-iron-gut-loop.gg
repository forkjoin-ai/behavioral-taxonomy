(loop_89_context_branch | loop_89_then_branch | loop_89_operator_branch | loop_89_result_branch | loop_89_taxonomy_branch | loop_89_intervention_recognize | loop_89_intervention_interdict | loop_89_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_89_verdict)
