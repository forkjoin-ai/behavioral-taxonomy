// behavioral-loop-98.gg
// Executable Gnosis projection for The Weak Chin Loop.

// Nodes
(loop_98_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_98_context_branch: BehaviorEmit { emission: 'context' })
(loop_98_given_gate: BehaviorAssess { stage: 'given', text: 'Receding%20Mandible%2FChin' })
(loop_98_inactive: BehaviorTerminal { loopId: 98, loopName: 'The%20Weak%20Chin%20Loop' })
(loop_98_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
