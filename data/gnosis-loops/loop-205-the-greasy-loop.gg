(loop_205_start: BehaviorStart { loopId: 205, loopName: 'The%20Greasy%20Loop', given: 'Hyper-active%20sebaceous%20glands', when: 'seen%20late%20in%20the%20day', then: 'observers%20assume%20%22Poor%20Hygiene%22%20or%20%22Depression%22%20(The%20Disgust%20Operator)', result: 'social%20avoidance%20despite%20the%20individual%20showering%20daily', operatorName: 'The%20Disgust%20Operator', operatorMechanism: 'observers%20assume%20%22Poor%20Hygiene%22%20or%20%22Depression%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'REPULSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
