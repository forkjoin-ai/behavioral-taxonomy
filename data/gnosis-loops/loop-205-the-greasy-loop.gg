(loop_205_verdict: BehaviorVerdict { loopId: 205, loopName: 'The%20Greasy%20Loop', then: 'observers%20assume%20%22Poor%20Hygiene%22%20or%20%22Depression%22%20(The%20Disgust%20Operator)', result: 'social%20avoidance%20despite%20the%20individual%20showering%20daily', operatorName: 'The%20Disgust%20Operator', operatorMechanism: 'observers%20assume%20%22Poor%20Hygiene%22%20or%20%22Depression%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'REPULSION' })
(loop_205_when_gate: BehaviorAssess { stage: 'when', text: 'seen%20late%20in%20the%20day' })

// Topology
(loop_205_start)-[:PROCESS]->(loop_205_given_gate)
(loop_205_given_gate)-[:PROCESS { case: "ok" }]->(loop_205_when_gate)
(loop_205_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_205_inactive)
(loop_205_when_gate)-[:PROCESS { case: "ok" }]->(loop_205_context)
(loop_205_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_205_inactive)
(loop_205_context)-[:FORK { strategy: "behavior-branches" }]->(loop_205_context_branch | loop_205_then_branch | loop_205_operator_branch | loop_205_result_branch | loop_205_taxonomy_branch | loop_205_intervention_recognize | loop_205_intervention_interdict | loop_205_intervention_minimize)
(loop_205_context_branch | loop_205_then_branch | loop_205_operator_branch | loop_205_result_branch | loop_205_taxonomy_branch | loop_205_intervention_recognize | loop_205_intervention_interdict | loop_205_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_205_verdict)
(loop_205_inactive)-[:PROCESS]->(loop_205_sink)
(loop_205_verdict)-[:PROCESS]->(loop_205_sink)
(loop_205_verdict)-[:MEASURE]->(loop_205_sink)
(loop_205_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_205_then_branch)
