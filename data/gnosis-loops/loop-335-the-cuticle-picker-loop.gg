(loop_335_given_gate: BehaviorAssess { stage: 'given', text: 'Picking%20at%20skin%20around%20nails' })
(loop_335_inactive: BehaviorTerminal { loopId: 335, loopName: 'The%20Cuticle%20Picker%20Loop' })
(loop_335_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22' })
(loop_335_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_335_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Watch%20for%20snap%20judgments%20based%20on%20appearance' })
(loop_335_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Self-Harm%20Operator', mechanism: 'it%20causes%20bleeding%2Fredness' })
