(loop_654_context_branch | loop_654_then_branch | loop_654_operator_branch | loop_654_result_branch | loop_654_taxonomy_branch | loop_654_intervention_recognize | loop_654_intervention_interdict | loop_654_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_654_verdict)
