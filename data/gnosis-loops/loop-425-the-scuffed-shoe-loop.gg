(loop_425_context)-[:FORK { strategy: "behavior-branches" }]->(loop_425_context_branch | loop_425_then_branch | loop_425_operator_branch | loop_425_result_branch | loop_425_taxonomy_branch | loop_425_intervention_recognize | loop_425_intervention_interdict | loop_425_intervention_minimize)
(loop_425_context_branch | loop_425_then_branch | loop_425_operator_branch | loop_425_result_branch | loop_425_taxonomy_branch | loop_425_intervention_recognize | loop_425_intervention_interdict | loop_425_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_425_verdict)
(loop_425_inactive)-[:PROCESS]->(loop_425_sink)
