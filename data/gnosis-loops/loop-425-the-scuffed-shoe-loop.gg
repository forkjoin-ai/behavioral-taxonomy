(loop_425_verdict: BehaviorVerdict { loopId: 425, loopName: 'The%20Scuffed%20Shoe%20Loop', then: 'the%20interviewer%20spots%20the%20neglect%20(The%20Sloppy%20Operator)', result: 'rejection%20based%20on%20the%20assumption%20that%20%22how%20you%20do%20one%20thing%20is%20how%20you%20do%20everything.%22', operatorName: 'The%20Sloppy%20Operator', operatorMechanism: 'the%20interviewer%20spots%20the%20neglect', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_425_when_gate: BehaviorAssess { stage: 'when', text: 'interviewed%20for%20a%20detail-oriented%20job%20(Law%2FAccounting)' })

// Topology
(loop_425_start)-[:PROCESS]->(loop_425_given_gate)
(loop_425_given_gate)-[:PROCESS { case: "ok" }]->(loop_425_when_gate)
(loop_425_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_425_inactive)
