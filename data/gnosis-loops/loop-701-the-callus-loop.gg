(loop_701_start: BehaviorStart { loopId: 701, loopName: 'The%20Callus%20Loop', given: 'Thick%2C%20yellowed%20skin%20on%20palms', when: 'shaking%20hands', then: 'it%20signals%20%22Hard%20Labor%22%20(The%20Roughneck%20Operator)', result: 'immediate%20respect%20from%20blue-collar%20peers%2C%20judgment%20from%20elites', operatorName: 'The%20Roughneck%20Operator', operatorMechanism: 'it%20signals%20%22Hard%20Labor%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
