(loop_701_context)-[:FORK { strategy: "behavior-branches" }]->(loop_701_context_branch | loop_701_then_branch | loop_701_operator_branch | loop_701_result_branch | loop_701_taxonomy_branch | loop_701_intervention_recognize | loop_701_intervention_interdict | loop_701_intervention_minimize)
