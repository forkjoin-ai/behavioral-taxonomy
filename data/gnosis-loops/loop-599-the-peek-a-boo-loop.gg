(loop_599_context)-[:FORK { strategy: "behavior-branches" }]->(loop_599_context_branch | loop_599_then_branch | loop_599_operator_branch | loop_599_result_branch | loop_599_taxonomy_branch | loop_599_intervention_recognize | loop_599_intervention_interdict | loop_599_intervention_minimize)
(loop_599_context_branch | loop_599_then_branch | loop_599_operator_branch | loop_599_result_branch | loop_599_taxonomy_branch | loop_599_intervention_recognize | loop_599_intervention_interdict | loop_599_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_599_verdict)
(loop_599_inactive)-[:PROCESS]->(loop_599_sink)
