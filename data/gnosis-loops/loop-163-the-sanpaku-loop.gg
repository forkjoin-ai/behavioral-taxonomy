// behavioral-loop-163.gg
// Executable Gnosis projection for The Sanpaku Loop.

// Nodes
(loop_163_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_163_context_branch: BehaviorEmit { emission: 'context' })
(loop_163_given_gate: BehaviorAssess { stage: 'given', text: 'Visible%20white%20space%20below%20the%20iris%20(Yin%20Sanpaku)' })
(loop_163_inactive: BehaviorTerminal { loopId: 163, loopName: 'The%20Sanpaku%20Loop' })
