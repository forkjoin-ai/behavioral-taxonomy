(loop_163_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Uncanny%20Operator', mechanism: 'observers%20perceive%20%22Exhaustion%2C%22%20%22Madness%2C%22%20or%20%22Spiritual%20Stress%22' })
