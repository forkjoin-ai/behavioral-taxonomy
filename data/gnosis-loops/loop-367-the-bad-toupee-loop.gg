(loop_367_start: BehaviorStart { loopId: 367, loopName: 'The%20Bad%20Toupee%20Loop', given: 'Mismatched%20hairpiece%20density%2Fcolor', when: 'talking%20to%20someone', then: 'the%20listener%20focuses%20entirely%20on%20the%20hairline%20(The%20Distraction%2FDishonesty%20Operator)', result: 'the%20individual%20being%20perceived%20as%20someone%20who%20cannot%20accept%20reality', operatorName: 'The%20Distraction%2FDishonesty%20Operator', operatorMechanism: 'the%20listener%20focuses%20entirely%20on%20the%20hairline', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
