(loop_367_verdict: BehaviorVerdict { loopId: 367, loopName: 'The%20Bad%20Toupee%20Loop', then: 'the%20listener%20focuses%20entirely%20on%20the%20hairline%20(The%20Distraction%2FDishonesty%20Operator)', result: 'the%20individual%20being%20perceived%20as%20someone%20who%20cannot%20accept%20reality', operatorName: 'The%20Distraction%2FDishonesty%20Operator', operatorMechanism: 'the%20listener%20focuses%20entirely%20on%20the%20hairline', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
