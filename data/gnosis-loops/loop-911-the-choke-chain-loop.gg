(loop_911_given_gate: BehaviorAssess { stage: 'given', text: 'Necklace%20or%20watch%20band%20digging%20into%20skin' })
(loop_911_inactive: BehaviorTerminal { loopId: 911, loopName: 'The%20Choke%20Chain%20Loop' })
(loop_911_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22' })
(loop_911_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
