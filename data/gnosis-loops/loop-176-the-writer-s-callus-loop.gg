(loop_176_context)-[:FORK { strategy: "behavior-branches" }]->(loop_176_context_branch | loop_176_then_branch | loop_176_operator_branch | loop_176_result_branch | loop_176_taxonomy_branch | loop_176_intervention_recognize | loop_176_intervention_interdict | loop_176_intervention_minimize)
