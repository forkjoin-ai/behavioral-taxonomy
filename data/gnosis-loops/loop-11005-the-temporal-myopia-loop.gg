(loop_11005_context_branch | loop_11005_then_branch | loop_11005_operator_branch | loop_11005_result_branch | loop_11005_taxonomy_branch | loop_11005_intervention_recognize | loop_11005_intervention_interdict | loop_11005_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_11005_verdict)
