(loop_11005_then_branch: BehaviorEmit { emission: 'then', text: 'Hyperbolic%20discounting%20causes%20future%20value%20to%20crash%20near%20zero%20(V%20%3D%20A%20%2F%20(1%20%2B%20kD))' })
(loop_11005_verdict: BehaviorVerdict { loopId: 11005, loopName: 'The%20Temporal%20Myopia%20Loop', then: 'Hyperbolic%20discounting%20causes%20future%20value%20to%20crash%20near%20zero%20(V%20%3D%20A%20%2F%20(1%20%2B%20kD))', result: 'Chronic%20failure%20to%20execute%20long-term%20goals%20despite%20rational%20intentions', operatorName: 'The%20Present%20Bias%20Calculator', operatorMechanism: "Future%20self%20is%20processed%20neurologically%20as%20a%20'stranger'%20(low%20dlPFC%20activity)%2C%20reducing%20resource%20sharing%20with%20one's%20own%20future.", origin: 'NEUROBIOLOGICAL', modality: 'DOPAMINERGIC', mutability: 'FLUID', valences: 'CONSUMPTION|HEDONISM' })
