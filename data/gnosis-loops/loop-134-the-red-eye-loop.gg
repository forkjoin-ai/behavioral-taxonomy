(loop_134_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_134_inactive)
(loop_134_context)-[:FORK { strategy: "behavior-branches" }]->(loop_134_context_branch | loop_134_then_branch | loop_134_operator_branch | loop_134_result_branch | loop_134_taxonomy_branch | loop_134_intervention_recognize | loop_134_intervention_leverage)
(loop_134_context_branch | loop_134_then_branch | loop_134_operator_branch | loop_134_result_branch | loop_134_taxonomy_branch | loop_134_intervention_recognize | loop_134_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_134_verdict)
(loop_134_inactive)-[:PROCESS]->(loop_134_sink)
(loop_134_verdict)-[:PROCESS]->(loop_134_sink)
(loop_134_verdict)-[:MEASURE]->(loop_134_sink)
(loop_134_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_134_then_branch)
