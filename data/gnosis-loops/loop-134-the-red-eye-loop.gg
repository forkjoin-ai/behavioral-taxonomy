// Topology
(loop_134_start)-[:PROCESS]->(loop_134_given_gate)
(loop_134_given_gate)-[:PROCESS { case: "ok" }]->(loop_134_when_gate)
(loop_134_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_134_inactive)
