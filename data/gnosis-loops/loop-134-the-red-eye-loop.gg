(loop_134_start: BehaviorStart { loopId: 134, loopName: 'The%20Red%20Eye%20Loop', given: 'Chronic%20dry%20eye%20or%20allergy%20(Redness)', when: 'making%20eye%20contact', then: 'observers%20assume%20%22Intoxication%2C%22%20%22Fatigue%2C%22%20or%20%22Infection%22%20(The%20Scrutiny%20Operator)', result: 'loss%20of%20professional%20credibility%20and%20frequent%20drug%20testing%2Fquestioning', operatorName: 'The%20Scrutiny%20Operator', operatorMechanism: 'observers%20assume%20%22Intoxication%2C%22%20%22Fatigue%2C%22%20or%20%22Infection%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'TRUST', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_leverage: 'Use%20in%20high-stakes%20negotiations%20and%20first%20impressions' })
