(loop_533_context)-[:FORK { strategy: "behavior-branches" }]->(loop_533_context_branch | loop_533_then_branch | loop_533_operator_branch | loop_533_result_branch | loop_533_taxonomy_branch | loop_533_intervention_recognize | loop_533_intervention_interdict | loop_533_intervention_minimize)
(loop_533_context_branch | loop_533_then_branch | loop_533_operator_branch | loop_533_result_branch | loop_533_taxonomy_branch | loop_533_intervention_recognize | loop_533_intervention_interdict | loop_533_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_533_verdict)
(loop_533_inactive)-[:PROCESS]->(loop_533_sink)
