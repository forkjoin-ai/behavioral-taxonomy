(loop_710_context_branch | loop_710_then_branch | loop_710_operator_branch | loop_710_result_branch | loop_710_taxonomy_branch | loop_710_intervention_recognize | loop_710_intervention_interdict | loop_710_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_710_verdict)
