(loop_898_context_branch | loop_898_then_branch | loop_898_operator_branch | loop_898_result_branch | loop_898_taxonomy_branch | loop_898_intervention_recognize | loop_898_intervention_interdict | loop_898_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_898_verdict)
