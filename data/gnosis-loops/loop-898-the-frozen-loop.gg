(loop_898_start: BehaviorStart { loopId: 898, loopName: 'The%20Frozen%20Loop', given: 'Paralysis%20of%20the%20corrugator%20muscles%20(frown%20lines)', when: 'expressing%20empathy%20or%20concern', then: 'the%20forehead%20remains%20smooth%20and%20blank%20(The%20Mask%20Operator)', result: 'the%20individual%20appearing%20%22Cold%22%20or%20%22Psychopathic%22%20despite%20feeling%20genuine%20emotion', operatorName: 'The%20Mask%20Operator', operatorMechanism: 'the%20forehead%20remains%20smooth%20and%20blank', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
