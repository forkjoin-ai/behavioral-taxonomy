// behavioral-loop-140.gg
// Executable Gnosis projection for The Swan Neck Loop.

// Nodes
(loop_140_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_140_context_branch: BehaviorEmit { emission: 'context' })
(loop_140_given_gate: BehaviorAssess { stage: 'given', text: 'Long%2C%20thin%20cervical%20spine' })
(loop_140_inactive: BehaviorTerminal { loopId: 140, loopName: 'The%20Swan%20Neck%20Loop' })
(loop_140_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22' })
(loop_140_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Seek%20feedback%20from%20trusted%20allies%20about%20perception%20gaps' })
(loop_140_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Watch%20for%20snap%20judgments%20based%20on%20appearance' })
(loop_140_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Halo%2FFragility%20Operator', mechanism: 'observers%20perceive%20%22Elegance%22%20but%20also%20%22Physical%20Weakness%22' })
(loop_140_result_branch: BehaviorEmit { emission: 'result', text: 'being%20protected%20from%20physical%20labor%20but%20admired%20for%20aesthetics' })
(loop_140_sink: BehaviorSink)
(loop_140_start: BehaviorStart { loopId: 140, loopName: 'The%20Swan%20Neck%20Loop', given: 'Long%2C%20thin%20cervical%20spine', when: 'looking%20in%20profile', then: 'observers%20perceive%20%22Elegance%22%20but%20also%20%22Physical%20Weakness%22%20(The%20Halo%2FFragility%20Operator)', result: 'being%20protected%20from%20physical%20labor%20but%20admired%20for%20aesthetics', operatorName: 'The%20Halo%2FFragility%20Operator', operatorMechanism: 'observers%20perceive%20%22Elegance%22%20but%20also%20%22Physical%20Weakness%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Seek%20feedback%20from%20trusted%20allies%20about%20perception%20gaps' })
(loop_140_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_140_then_branch: BehaviorEmit { emission: 'then', text: 'observers%20perceive%20%22Elegance%22%20but%20also%20%22Physical%20Weakness%22%20(The%20Halo%2FFragility%20Operator)' })
(loop_140_verdict: BehaviorVerdict { loopId: 140, loopName: 'The%20Swan%20Neck%20Loop', then: 'observers%20perceive%20%22Elegance%22%20but%20also%20%22Physical%20Weakness%22%20(The%20Halo%2FFragility%20Operator)', result: 'being%20protected%20from%20physical%20labor%20but%20admired%20for%20aesthetics', operatorName: 'The%20Halo%2FFragility%20Operator', operatorMechanism: 'observers%20perceive%20%22Elegance%22%20but%20also%20%22Physical%20Weakness%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_140_when_gate: BehaviorAssess { stage: 'when', text: 'looking%20in%20profile' })

// Topology
(loop_140_start)-[:PROCESS]->(loop_140_given_gate)
(loop_140_given_gate)-[:PROCESS { case: "ok" }]->(loop_140_when_gate)
(loop_140_given_gate)-[:PROCESS { case: "err" }]->(loop_140_inactive)
(loop_140_when_gate)-[:PROCESS { case: "ok" }]->(loop_140_context)
(loop_140_when_gate)-[:PROCESS { case: "err" }]->(loop_140_inactive)
(loop_140_context)-[:FORK { strategy: "behavior-branches" }]->(loop_140_context_branch | loop_140_then_branch | loop_140_operator_branch | loop_140_result_branch | loop_140_taxonomy_branch | loop_140_intervention_recognize | loop_140_intervention_interdict | loop_140_intervention_minimize)
(loop_140_context_branch | loop_140_then_branch | loop_140_operator_branch | loop_140_result_branch | loop_140_taxonomy_branch | loop_140_intervention_recognize | loop_140_intervention_interdict | loop_140_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_140_verdict)
(loop_140_inactive)-[:PROCESS]->(loop_140_sink)
(loop_140_verdict)-[:PROCESS]->(loop_140_sink)
(loop_140_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_140_then_branch)
(loop_140_intervention_interdict)-[:INTERFERE { mode: "destructive" }]->(loop_140_then_branch)
(loop_140_intervention_minimize)-[:INTERFERE { mode: "destructive" }]->(loop_140_then_branch)