(loop_702_when_gate)-[:PROCESS { case: "err" }]->(loop_702_inactive)
(loop_702_context)-[:FORK { strategy: "behavior-branches" }]->(loop_702_context_branch | loop_702_then_branch | loop_702_operator_branch | loop_702_result_branch | loop_702_taxonomy_branch | loop_702_intervention_recognize | loop_702_intervention_interdict | loop_702_intervention_minimize)
(loop_702_context_branch | loop_702_then_branch | loop_702_operator_branch | loop_702_result_branch | loop_702_taxonomy_branch | loop_702_intervention_recognize | loop_702_intervention_interdict | loop_702_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_702_verdict)
(loop_702_inactive)-[:PROCESS]->(loop_702_sink)
(loop_702_verdict)-[:PROCESS]->(loop_702_sink)
(loop_702_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_702_then_branch)
(loop_702_intervention_interdict)-[:INTERFERE { mode: "destructive" }]->(loop_702_then_branch)
