(loop_863_start: BehaviorStart { loopId: 863, loopName: 'The%20Shuffle%20Loop', given: 'Small%2C%20rapid%20steps%20without%20arm%20swing', when: 'approaching', then: 'it%20signals%20%22Age%22%20or%20%22Parkinsonian%22%20traits%20(The%20Frail%20Operator)', result: 'people%20opening%20doors%20and%20offering%20help%20unprompted', operatorName: 'The%20Frail%20Operator', operatorMechanism: 'it%20signals%20%22Age%22%20or%20%22Parkinsonian%22%20traits', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_863_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_863_then_branch: BehaviorEmit { emission: 'then', text: 'it%20signals%20%22Age%22%20or%20%22Parkinsonian%22%20traits%20(The%20Frail%20Operator)' })
(loop_863_verdict: BehaviorVerdict { loopId: 863, loopName: 'The%20Shuffle%20Loop', then: 'it%20signals%20%22Age%22%20or%20%22Parkinsonian%22%20traits%20(The%20Frail%20Operator)', result: 'people%20opening%20doors%20and%20offering%20help%20unprompted', operatorName: 'The%20Frail%20Operator', operatorMechanism: 'it%20signals%20%22Age%22%20or%20%22Parkinsonian%22%20traits', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
