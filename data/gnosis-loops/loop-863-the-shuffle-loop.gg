(loop_863_inactive: BehaviorTerminal { loopId: 863, loopName: 'The%20Shuffle%20Loop' })
(loop_863_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
