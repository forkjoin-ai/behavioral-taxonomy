(loop_217_context)-[:FORK { strategy: "behavior-branches" }]->(loop_217_context_branch | loop_217_then_branch | loop_217_operator_branch | loop_217_result_branch | loop_217_taxonomy_branch | loop_217_intervention_recognize | loop_217_intervention_interdict | loop_217_intervention_minimize)
(loop_217_context_branch | loop_217_then_branch | loop_217_operator_branch | loop_217_result_branch | loop_217_taxonomy_branch | loop_217_intervention_recognize | loop_217_intervention_interdict | loop_217_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_217_verdict)
(loop_217_inactive)-[:PROCESS]->(loop_217_sink)
