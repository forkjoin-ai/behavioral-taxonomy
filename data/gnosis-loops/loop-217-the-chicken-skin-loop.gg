(loop_217_start: BehaviorStart { loopId: 217, loopName: 'The%20Chicken%20Skin%20Loop', given: 'Red%20bumps%20on%20upper%20arms', when: 'wearing%20sleeveless%20tops', then: 'observers%20assume%20%22Rash%22%20or%20%22Infection%22%20(The%20Hygiene%20Operator)', result: 'the%20individual%20wearing%20long%20sleeves%20in%20summer%2C%20leading%20to%20**Thermal%20Stress**', operatorName: 'The%20Hygiene%20Operator', operatorMechanism: 'observers%20assume%20%22Rash%22%20or%20%22Infection%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
