(loop_387_context_branch | loop_387_then_branch | loop_387_operator_branch | loop_387_result_branch | loop_387_taxonomy_branch | loop_387_intervention_recognize | loop_387_intervention_interdict | loop_387_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_387_verdict)
