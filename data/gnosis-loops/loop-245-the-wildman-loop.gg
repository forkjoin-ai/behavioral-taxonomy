// behavioral-loop-245.gg
// Executable Gnosis projection for The Wildman Loop.

// Nodes
(loop_245_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_245_context_branch: BehaviorEmit { emission: 'context' })
(loop_245_given_gate: BehaviorAssess { stage: 'given', text: 'Patchy%20or%20explosive%20facial%20hair%20growth' })
(loop_245_inactive: BehaviorTerminal { loopId: 245, loopName: 'The%20Wildman%20Loop' })
(loop_245_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Proactively%20seek%20social%20exposure%20in%20safe%2C%20low-stakes%20environments%20to%20break%20the%20cycle.' })
(loop_245_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_245_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong' })
(loop_245_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Fear%20Operator', mechanism: 'strangers%20cross%20the%20street%20to%20avoid%20%22Homelessness%22%20or%20%22Insanity%22%20risk' })
(loop_245_result_branch: BehaviorEmit { emission: 'result', text: 'extreme%20**Social%20Isolation**' })
(loop_245_sink: BehaviorSink)
(loop_245_start: BehaviorStart { loopId: 245, loopName: 'The%20Wildman%20Loop', given: 'Patchy%20or%20explosive%20facial%20hair%20growth', when: 'walking%20on%20the%20street', then: 'strangers%20cross%20the%20street%20to%20avoid%20%22Homelessness%22%20or%20%22Insanity%22%20risk%20(The%20Fear%20Operator)', result: 'extreme%20**Social%20Isolation**', operatorName: 'The%20Fear%20Operator', operatorMechanism: 'strangers%20cross%20the%20street%20to%20avoid%20%22Homelessness%22%20or%20%22Insanity%22%20risk', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Proactively%20seek%20social%20exposure%20in%20safe%2C%20low-stakes%20environments%20to%20break%20the%20cycle.', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_245_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_245_then_branch: BehaviorEmit { emission: 'then', text: 'strangers%20cross%20the%20street%20to%20avoid%20%22Homelessness%22%20or%20%22Insanity%22%20risk%20(The%20Fear%20Operator)' })
(loop_245_verdict: BehaviorVerdict { loopId: 245, loopName: 'The%20Wildman%20Loop', then: 'strangers%20cross%20the%20street%20to%20avoid%20%22Homelessness%22%20or%20%22Insanity%22%20risk%20(The%20Fear%20Operator)', result: 'extreme%20**Social%20Isolation**', operatorName: 'The%20Fear%20Operator', operatorMechanism: 'strangers%20cross%20the%20street%20to%20avoid%20%22Homelessness%22%20or%20%22Insanity%22%20risk', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_245_when_gate: BehaviorAssess { stage: 'when', text: 'walking%20on%20the%20street' })

// Topology
(loop_245_start)-[:PROCESS]->(loop_245_given_gate)
(loop_245_given_gate)-[:PROCESS { case: "ok" }]->(loop_245_when_gate)
(loop_245_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_245_inactive)
(loop_245_when_gate)-[:PROCESS { case: "ok" }]->(loop_245_context)
(loop_245_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_245_inactive)
(loop_245_context)-[:FORK { strategy: "behavior-branches" }]->(loop_245_context_branch | loop_245_then_branch | loop_245_operator_branch | loop_245_result_branch | loop_245_taxonomy_branch | loop_245_intervention_recognize | loop_245_intervention_interdict | loop_245_intervention_minimize)
(loop_245_context_branch | loop_245_then_branch | loop_245_operator_branch | loop_245_result_branch | loop_245_taxonomy_branch | loop_245_intervention_recognize | loop_245_intervention_interdict | loop_245_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_245_verdict)
(loop_245_inactive)-[:PROCESS]->(loop_245_sink)
(loop_245_verdict)-[:PROCESS]->(loop_245_sink)
(loop_245_verdict)-[:MEASURE]->(loop_245_sink)
(loop_245_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_245_then_branch)
(loop_245_intervention_interdict)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_245_then_branch)
(loop_245_intervention_minimize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_245_then_branch)