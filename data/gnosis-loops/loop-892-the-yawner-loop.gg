// Topology
(loop_892_start)-[:PROCESS]->(loop_892_given_gate)
(loop_892_given_gate)-[:PROCESS { case: "ok" }]->(loop_892_when_gate)
(loop_892_given_gate)-[:PROCESS { case: "err" }]->(loop_892_inactive)
(loop_892_when_gate)-[:PROCESS { case: "ok" }]->(loop_892_context)
