(loop_892_result_branch: BehaviorEmit { emission: 'result', text: 'the%20speaker%20feeling%20insulted' })
(loop_892_sink: BehaviorSink)
(loop_892_start: BehaviorStart { loopId: 892, loopName: 'The%20Yawner%20Loop', given: 'Frequent%20yawning%20to%20cool%20the%20brain%20(not%20boredom)', when: 'listening%20intently', then: 'it%20looks%20like%20%22Disinterest%22%20(The%20Rude%20Operator)', result: 'the%20speaker%20feeling%20insulted', operatorName: 'The%20Rude%20Operator', operatorMechanism: 'it%20looks%20like%20%22Disinterest%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_892_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_892_then_branch: BehaviorEmit { emission: 'then', text: 'it%20looks%20like%20%22Disinterest%22%20(The%20Rude%20Operator)' })
(loop_892_verdict: BehaviorVerdict { loopId: 892, loopName: 'The%20Yawner%20Loop', then: 'it%20looks%20like%20%22Disinterest%22%20(The%20Rude%20Operator)', result: 'the%20speaker%20feeling%20insulted', operatorName: 'The%20Rude%20Operator', operatorMechanism: 'it%20looks%20like%20%22Disinterest%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
