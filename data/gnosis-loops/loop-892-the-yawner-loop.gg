// behavioral-loop-892.gg
// Executable Gnosis projection for The Yawner Loop.

// Nodes
(loop_892_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_892_context_branch: BehaviorEmit { emission: 'context' })
(loop_892_given_gate: BehaviorAssess { stage: 'given', text: 'Frequent%20yawning%20to%20cool%20the%20brain%20(not%20boredom)' })
(loop_892_inactive: BehaviorTerminal { loopId: 892, loopName: 'The%20Yawner%20Loop' })
(loop_892_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
(loop_892_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
