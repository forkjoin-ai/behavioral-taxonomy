(loop_910_inactive: BehaviorTerminal { loopId: 910, loopName: 'The%20Screen%20Glow%20Loop' })
(loop_910_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
