(loop_435_context)-[:FORK { strategy: "behavior-branches" }]->(loop_435_context_branch | loop_435_then_branch | loop_435_operator_branch | loop_435_result_branch | loop_435_taxonomy_branch | loop_435_intervention_recognize | loop_435_intervention_interdict | loop_435_intervention_minimize)
(loop_435_context_branch | loop_435_then_branch | loop_435_operator_branch | loop_435_result_branch | loop_435_taxonomy_branch | loop_435_intervention_recognize | loop_435_intervention_interdict | loop_435_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_435_verdict)
(loop_435_inactive)-[:PROCESS]->(loop_435_sink)
