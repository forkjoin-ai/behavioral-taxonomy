(loop_435_start: BehaviorStart { loopId: 435, loopName: 'The%20Razor%20Burn%20Loop', given: 'Red%20bumps%20on%20the%20neck%2Fface%20from%20shaving', when: 'arriving%20at%20work', then: 'it%20looks%20like%20%22Rash%22%20or%20%22Incompetence%22%20with%20tools%20(The%20Amateur%20Operator)', result: 'the%20individual%20looking%20less%20%22Polished%22%20than%20bearded%20peers', operatorName: 'The%20Amateur%20Operator', operatorMechanism: 'it%20looks%20like%20%22Rash%22%20or%20%22Incompetence%22%20with%20tools', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
