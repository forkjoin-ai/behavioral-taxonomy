(loop_1034_when_gate)-[:PROCESS { case: "err" }]->(loop_1034_inactive)
(loop_1034_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1034_context_branch | loop_1034_then_branch | loop_1034_operator_branch | loop_1034_result_branch | loop_1034_taxonomy_branch | loop_1034_intervention_recognize | loop_1034_intervention_interdict | loop_1034_intervention_minimize)
(loop_1034_context_branch | loop_1034_then_branch | loop_1034_operator_branch | loop_1034_result_branch | loop_1034_taxonomy_branch | loop_1034_intervention_recognize | loop_1034_intervention_interdict | loop_1034_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1034_verdict)
(loop_1034_inactive)-[:PROCESS]->(loop_1034_sink)
