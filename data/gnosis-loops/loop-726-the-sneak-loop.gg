// behavioral-loop-726.gg
// Executable Gnosis projection for The Sneak Loop.

// Nodes
(loop_726_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_726_context_branch: BehaviorEmit { emission: 'context' })
(loop_726_given_gate: BehaviorAssess { stage: 'given', text: 'Silent%2C%20ball-of-foot%20gait' })
(loop_726_inactive: BehaviorTerminal { loopId: 726, loopName: 'The%20Sneak%20Loop' })
(loop_726_intervention_leverage: BehaviorEmit { emission: 'intervention', interventionKind: 'leverage', text: 'Use%20in%20high-stakes%20negotiations%20and%20first%20impressions' })
