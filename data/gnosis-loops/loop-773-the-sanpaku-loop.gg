(loop_773_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Kennedy%20Operator', mechanism: 'it%20signals%20%22Spiritual%20Imbalance%2C%22%20%22Exhaustion%2C%22%20or%20%22Madness%22' })
