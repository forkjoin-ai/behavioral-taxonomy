(loop_777_inactive: BehaviorTerminal { loopId: 777, loopName: 'The%20Sandpaper%20Loop' })
(loop_777_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
