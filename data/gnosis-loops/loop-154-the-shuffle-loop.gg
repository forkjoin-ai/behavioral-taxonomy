(loop_154_context_branch | loop_154_then_branch | loop_154_operator_branch | loop_154_result_branch | loop_154_taxonomy_branch | loop_154_intervention_recognize | loop_154_intervention_interdict | loop_154_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_154_verdict)
