// Topology
(loop_604_start)-[:PROCESS]->(loop_604_given_gate)
(loop_604_given_gate)-[:PROCESS { case: "ok" }]->(loop_604_when_gate)
(loop_604_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_604_inactive)
