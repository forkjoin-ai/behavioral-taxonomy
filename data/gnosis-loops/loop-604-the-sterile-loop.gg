(loop_604_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_604_inactive)
(loop_604_context)-[:FORK { strategy: "behavior-branches" }]->(loop_604_context_branch | loop_604_then_branch | loop_604_operator_branch | loop_604_result_branch | loop_604_taxonomy_branch | loop_604_intervention_recognize | loop_604_intervention_interdict | loop_604_intervention_minimize)
(loop_604_context_branch | loop_604_then_branch | loop_604_operator_branch | loop_604_result_branch | loop_604_taxonomy_branch | loop_604_intervention_recognize | loop_604_intervention_interdict | loop_604_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_604_verdict)
(loop_604_inactive)-[:PROCESS]->(loop_604_sink)
