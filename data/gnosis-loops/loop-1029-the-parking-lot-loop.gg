// behavioral-loop-1029.gg
// Executable Gnosis projection for The Parking Lot Loop.

// Nodes
(loop_1029_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_1029_context_branch: BehaviorEmit { emission: 'context' })
(loop_1029_given_gate: BehaviorAssess { stage: 'given', text: 'Difficulty%20switching%20tasks%20(ADHD%2FAutism)' })
(loop_1029_inactive: BehaviorTerminal { loopId: 1029, loopName: 'The%20Parking%20Lot%20Loop' })
