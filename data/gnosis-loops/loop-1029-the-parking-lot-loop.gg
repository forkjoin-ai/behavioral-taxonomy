(loop_1029_when_gate)-[:PROCESS { case: "err" }]->(loop_1029_inactive)
(loop_1029_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1029_context_branch | loop_1029_then_branch | loop_1029_operator_branch | loop_1029_result_branch | loop_1029_taxonomy_branch | loop_1029_intervention_recognize | loop_1029_intervention_interdict | loop_1029_intervention_minimize)
(loop_1029_context_branch | loop_1029_then_branch | loop_1029_operator_branch | loop_1029_result_branch | loop_1029_taxonomy_branch | loop_1029_intervention_recognize | loop_1029_intervention_interdict | loop_1029_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1029_verdict)
(loop_1029_inactive)-[:PROCESS]->(loop_1029_sink)
(loop_1029_verdict)-[:PROCESS]->(loop_1029_sink)
(loop_1029_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_1029_then_branch)
