(loop_173_given_gate: BehaviorAssess { stage: 'given', text: 'Ragged%2C%20bleeding%20cuticles' })
(loop_173_inactive: BehaviorTerminal { loopId: 173, loopName: 'The%20Bitten%20Nail%20Loop' })
(loop_173_intervention_leverage: BehaviorEmit { emission: 'intervention', interventionKind: 'leverage', text: 'Use%20in%20high-stakes%20negotiations%20and%20first%20impressions' })
