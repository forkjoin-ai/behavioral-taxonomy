// behavioral-loop-1022.gg
// Executable Gnosis projection for The Martyr Loop.

// Nodes
(loop_1022_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_1022_context_branch: BehaviorEmit { emission: 'context' })
(loop_1022_given_gate: BehaviorAssess { stage: 'given', text: 'Need%20for%20validation%20through%20suffering' })
(loop_1022_inactive: BehaviorTerminal { loopId: 1022, loopName: 'The%20Martyr%20Loop' })
(loop_1022_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
(loop_1022_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
