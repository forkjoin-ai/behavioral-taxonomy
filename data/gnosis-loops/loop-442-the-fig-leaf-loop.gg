(loop_442_context)-[:FORK { strategy: "behavior-branches" }]->(loop_442_context_branch | loop_442_then_branch | loop_442_operator_branch | loop_442_result_branch | loop_442_taxonomy_branch | loop_442_intervention_recognize | loop_442_intervention_interdict | loop_442_intervention_minimize)
(loop_442_context_branch | loop_442_then_branch | loop_442_operator_branch | loop_442_result_branch | loop_442_taxonomy_branch | loop_442_intervention_recognize | loop_442_intervention_interdict | loop_442_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_442_verdict)
(loop_442_inactive)-[:PROCESS]->(loop_442_sink)
(loop_442_verdict)-[:PROCESS]->(loop_442_sink)
(loop_442_verdict)-[:MEASURE]->(loop_442_sink)
