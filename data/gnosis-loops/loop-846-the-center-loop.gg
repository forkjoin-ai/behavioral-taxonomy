// Topology
(loop_846_start)-[:PROCESS]->(loop_846_given_gate)
(loop_846_given_gate)-[:PROCESS { case: "ok" }]->(loop_846_when_gate)
(loop_846_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_846_inactive)
(loop_846_when_gate)-[:PROCESS { case: "ok" }]->(loop_846_context)
(loop_846_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_846_inactive)
(loop_846_context)-[:FORK { strategy: "behavior-branches" }]->(loop_846_context_branch | loop_846_then_branch | loop_846_operator_branch | loop_846_result_branch | loop_846_taxonomy_branch | loop_846_intervention_recognize | loop_846_intervention_interdict | loop_846_intervention_minimize)
(loop_846_context_branch | loop_846_then_branch | loop_846_operator_branch | loop_846_result_branch | loop_846_taxonomy_branch | loop_846_intervention_recognize | loop_846_intervention_interdict | loop_846_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_846_verdict)
(loop_846_inactive)-[:PROCESS]->(loop_846_sink)
(loop_846_verdict)-[:PROCESS]->(loop_846_sink)
(loop_846_verdict)-[:MEASURE]->(loop_846_sink)
(loop_846_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_846_then_branch)
(loop_846_intervention_interdict)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_846_then_branch)
