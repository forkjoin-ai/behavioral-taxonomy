(loop_846_inactive: BehaviorTerminal { loopId: 846, loopName: 'The%20Center%20Loop' })
(loop_846_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Change%20or%20modify%20the%20triggering%20environment' })
