// Topology
(loop_183_start)-[:PROCESS]->(loop_183_given_gate)
(loop_183_given_gate)-[:PROCESS { case: "ok" }]->(loop_183_when_gate)
(loop_183_given_gate)-[:PROCESS { case: "err" }]->(loop_183_inactive)
(loop_183_when_gate)-[:PROCESS { case: "ok" }]->(loop_183_context)
