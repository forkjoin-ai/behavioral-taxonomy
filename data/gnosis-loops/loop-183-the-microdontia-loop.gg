(loop_183_context)-[:FORK { strategy: "behavior-branches" }]->(loop_183_context_branch | loop_183_then_branch | loop_183_operator_branch | loop_183_result_branch | loop_183_taxonomy_branch | loop_183_intervention_recognize | loop_183_intervention_leverage)
(loop_183_context_branch | loop_183_then_branch | loop_183_operator_branch | loop_183_result_branch | loop_183_taxonomy_branch | loop_183_intervention_recognize | loop_183_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_183_verdict)
(loop_183_inactive)-[:PROCESS]->(loop_183_sink)
(loop_183_verdict)-[:PROCESS]->(loop_183_sink)
(loop_183_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_183_then_branch)
(loop_183_intervention_leverage)-[:INTERFERE { mode: "constructive" }]->(loop_183_result_branch)