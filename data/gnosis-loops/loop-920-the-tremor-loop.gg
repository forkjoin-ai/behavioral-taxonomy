// Topology
(loop_920_start)-[:PROCESS]->(loop_920_given_gate)
(loop_920_given_gate)-[:PROCESS { case: "ok" }]->(loop_920_when_gate)
(loop_920_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_920_inactive)
