(loop_920_start: BehaviorStart { loopId: 920, loopName: 'The%20Tremor%20Loop', given: 'Fine%20motor%20shake%20(Caffeine%2FNerves%2FEssential)', when: 'holding%20a%20paper%20or%20laser%20pointer', then: 'the%20movement%20is%20amplified%20(The%20Earthquake%20Operator)', result: 'the%20audience%20focusing%20on%20the%20*shake*%20rather%20than%20the%20content', operatorName: 'The%20Earthquake%20Operator', operatorMechanism: 'the%20movement%20is%20amplified', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '5', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_920_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_920_then_branch: BehaviorEmit { emission: 'then', text: 'the%20movement%20is%20amplified%20(The%20Earthquake%20Operator)' })
(loop_920_verdict: BehaviorVerdict { loopId: 920, loopName: 'The%20Tremor%20Loop', then: 'the%20movement%20is%20amplified%20(The%20Earthquake%20Operator)', result: 'the%20audience%20focusing%20on%20the%20*shake*%20rather%20than%20the%20content', operatorName: 'The%20Earthquake%20Operator', operatorMechanism: 'the%20movement%20is%20amplified', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
