(loop_920_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_920_inactive)
(loop_920_context)-[:FORK { strategy: "behavior-branches" }]->(loop_920_context_branch | loop_920_then_branch | loop_920_operator_branch | loop_920_result_branch | loop_920_taxonomy_branch | loop_920_intervention_recognize | loop_920_intervention_interdict | loop_920_intervention_minimize)
(loop_920_context_branch | loop_920_then_branch | loop_920_operator_branch | loop_920_result_branch | loop_920_taxonomy_branch | loop_920_intervention_recognize | loop_920_intervention_interdict | loop_920_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_920_verdict)
(loop_920_inactive)-[:PROCESS]->(loop_920_sink)
(loop_920_verdict)-[:PROCESS]->(loop_920_sink)
(loop_920_verdict)-[:MEASURE]->(loop_920_sink)
