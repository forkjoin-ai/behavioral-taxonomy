// Topology
(loop_807_start)-[:PROCESS]->(loop_807_given_gate)
(loop_807_given_gate)-[:PROCESS { case: "ok" }]->(loop_807_when_gate)
(loop_807_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_807_inactive)
(loop_807_when_gate)-[:PROCESS { case: "ok" }]->(loop_807_context)
(loop_807_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_807_inactive)
(loop_807_context)-[:FORK { strategy: "behavior-branches" }]->(loop_807_context_branch | loop_807_then_branch | loop_807_operator_branch | loop_807_result_branch | loop_807_taxonomy_branch | loop_807_intervention_recognize | loop_807_intervention_interdict | loop_807_intervention_minimize)
(loop_807_context_branch | loop_807_then_branch | loop_807_operator_branch | loop_807_result_branch | loop_807_taxonomy_branch | loop_807_intervention_recognize | loop_807_intervention_interdict | loop_807_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_807_verdict)
(loop_807_inactive)-[:PROCESS]->(loop_807_sink)
(loop_807_verdict)-[:PROCESS]->(loop_807_sink)
(loop_807_verdict)-[:MEASURE]->(loop_807_sink)
(loop_807_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_807_then_branch)
(loop_807_intervention_interdict)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_807_then_branch)
