(loop_807_start: BehaviorStart { loopId: 807, loopName: 'The%20Tremble%20Loop', given: 'Visible%20shivering%20in%20a%20warm%20room', when: 'sitting', then: 'it%20signals%20%22Systemic%20Shock%22%20or%20%22Withdrawal%22%20(The%20Shake%20Operator)', result: 'concern%20or%20suspicion%20of%20drug%20dependency', operatorName: 'The%20Shake%20Operator', operatorMechanism: 'it%20signals%20%22Systemic%20Shock%22%20or%20%22Withdrawal%22', origin: 'ENVIRONMENTAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'DECEPTION', interventionDifficulty: '5', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Change%20or%20modify%20the%20triggering%20environment', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
(loop_807_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'ENVIRONMENTAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'DECEPTION' })
(loop_807_then_branch: BehaviorEmit { emission: 'then', text: 'it%20signals%20%22Systemic%20Shock%22%20or%20%22Withdrawal%22%20(The%20Shake%20Operator)' })
(loop_807_verdict: BehaviorVerdict { loopId: 807, loopName: 'The%20Tremble%20Loop', then: 'it%20signals%20%22Systemic%20Shock%22%20or%20%22Withdrawal%22%20(The%20Shake%20Operator)', result: 'concern%20or%20suspicion%20of%20drug%20dependency', operatorName: 'The%20Shake%20Operator', operatorMechanism: 'it%20signals%20%22Systemic%20Shock%22%20or%20%22Withdrawal%22', origin: 'ENVIRONMENTAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'DECEPTION' })
