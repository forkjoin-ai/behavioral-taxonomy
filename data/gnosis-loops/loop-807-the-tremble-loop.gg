(loop_807_inactive: BehaviorTerminal { loopId: 807, loopName: 'The%20Tremble%20Loop' })
(loop_807_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Change%20or%20modify%20the%20triggering%20environment' })
