(loop_912_start: BehaviorStart { loopId: 912, loopName: 'The%20Dirty%20Lens%20Loop', given: 'Fingerprints%2Foil%20on%20glasses', when: 'looking%20at%20the%20wearer', then: 'observers%20focus%20on%20the%20grime%2C%20not%20the%20eyes%20(The%20Fog%20Operator)', result: 'judgments%20of%20%22Sloppiness%22%20and%20%22Poor%20Vision.%22', operatorName: 'The%20Fog%20Operator', operatorMechanism: 'observers%20focus%20on%20the%20grime%2C%20not%20the%20eyes', origin: 'SARTORIAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Introduce%20counterbalancing%20signals', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
(loop_912_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'SARTORIAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_912_then_branch: BehaviorEmit { emission: 'then', text: 'observers%20focus%20on%20the%20grime%2C%20not%20the%20eyes%20(The%20Fog%20Operator)' })
