// Topology
(loop_695_start)-[:PROCESS]->(loop_695_given_gate)
(loop_695_given_gate)-[:PROCESS { case: "ok" }]->(loop_695_when_gate)
(loop_695_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_695_inactive)
(loop_695_when_gate)-[:PROCESS { case: "ok" }]->(loop_695_context)
(loop_695_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_695_inactive)
(loop_695_context)-[:FORK { strategy: "behavior-branches" }]->(loop_695_context_branch | loop_695_then_branch | loop_695_operator_branch | loop_695_result_branch | loop_695_taxonomy_branch | loop_695_intervention_recognize | loop_695_intervention_interdict | loop_695_intervention_minimize)
(loop_695_context_branch | loop_695_then_branch | loop_695_operator_branch | loop_695_result_branch | loop_695_taxonomy_branch | loop_695_intervention_recognize | loop_695_intervention_interdict | loop_695_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_695_verdict)
(loop_695_inactive)-[:PROCESS]->(loop_695_sink)
(loop_695_verdict)-[:PROCESS]->(loop_695_sink)
(loop_695_verdict)-[:MEASURE]->(loop_695_sink)
