(loop_695_inactive: BehaviorTerminal { loopId: 695, loopName: 'The%20Fig%20Leaf%20Loop' })
(loop_695_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
