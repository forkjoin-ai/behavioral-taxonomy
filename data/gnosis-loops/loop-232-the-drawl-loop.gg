(loop_232_given_gate: BehaviorAssess { stage: 'given', text: 'Slow%20speech%20cadence%20(Regional%20or%20Neurological)' })
(loop_232_inactive: BehaviorTerminal { loopId: 232, loopName: 'The%20Drawl%20Loop' })
