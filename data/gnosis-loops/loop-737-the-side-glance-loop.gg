(loop_737_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong' })
(loop_737_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Spy%20Operator', mechanism: 'it%20signals%20%22Suspicion%2C%22%20%22Attraction%2C%22%20or%20%22Checking%20for%20Threats%22' })
(loop_737_result_branch: BehaviorEmit { emission: 'result', text: 'the%20target%20feeling%20monitored%20or%20singled%20out' })
