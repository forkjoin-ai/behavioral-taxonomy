// behavioral-loop-737.gg
// Executable Gnosis projection for The Side-Glance Loop.

// Nodes
(loop_737_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_737_context_branch: BehaviorEmit { emission: 'context' })
(loop_737_given_gate: BehaviorAssess { stage: 'given', text: 'Looking%20at%20someone%20without%20turning%20the%20head' })
(loop_737_inactive: BehaviorTerminal { loopId: 737, loopName: 'The%20Side-Glance%20Loop' })
