(loop_756_context)-[:FORK { strategy: "behavior-branches" }]->(loop_756_context_branch | loop_756_then_branch | loop_756_operator_branch | loop_756_result_branch | loop_756_taxonomy_branch | loop_756_intervention_recognize | loop_756_intervention_interdict | loop_756_intervention_minimize)
(loop_756_context_branch | loop_756_then_branch | loop_756_operator_branch | loop_756_result_branch | loop_756_taxonomy_branch | loop_756_intervention_recognize | loop_756_intervention_interdict | loop_756_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_756_verdict)
(loop_756_inactive)-[:PROCESS]->(loop_756_sink)
(loop_756_verdict)-[:PROCESS]->(loop_756_sink)
(loop_756_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_756_then_branch)
(loop_756_intervention_interdict)-[:INTERFERE { mode: "destructive" }]->(loop_756_then_branch)
