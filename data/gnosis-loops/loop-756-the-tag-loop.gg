// Topology
(loop_756_start)-[:PROCESS]->(loop_756_given_gate)
(loop_756_given_gate)-[:PROCESS { case: "ok" }]->(loop_756_when_gate)
(loop_756_given_gate)-[:PROCESS { case: "err" }]->(loop_756_inactive)
