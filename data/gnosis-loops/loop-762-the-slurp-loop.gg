// Topology
(loop_762_start)-[:PROCESS]->(loop_762_given_gate)
(loop_762_given_gate)-[:PROCESS { case: "ok" }]->(loop_762_when_gate)
(loop_762_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_762_inactive)
