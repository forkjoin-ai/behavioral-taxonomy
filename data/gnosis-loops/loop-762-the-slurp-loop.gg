(loop_762_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_762_inactive)
(loop_762_context)-[:FORK { strategy: "behavior-branches" }]->(loop_762_context_branch | loop_762_then_branch | loop_762_operator_branch | loop_762_result_branch | loop_762_taxonomy_branch | loop_762_intervention_recognize | loop_762_intervention_interdict | loop_762_intervention_minimize)
(loop_762_context_branch | loop_762_then_branch | loop_762_operator_branch | loop_762_result_branch | loop_762_taxonomy_branch | loop_762_intervention_recognize | loop_762_intervention_interdict | loop_762_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_762_verdict)
(loop_762_inactive)-[:PROCESS]->(loop_762_sink)
