(loop_762_then_branch: BehaviorEmit { emission: 'then', text: 'it%20signals%20%22Comfort%22%20(East)%20or%20%22Rudeness%22%20(West)%20(The%20Culture%20Clash%20Operator)' })
(loop_762_verdict: BehaviorVerdict { loopId: 762, loopName: 'The%20Slurp%20Loop', then: 'it%20signals%20%22Comfort%22%20(East)%20or%20%22Rudeness%22%20(West)%20(The%20Culture%20Clash%20Operator)', result: 'binary%20social%20judgment%20depending%20on%20location', operatorName: 'The%20Culture%20Clash%20Operator', operatorMechanism: 'it%20signals%20%22Comfort%22or%20%22Rudeness%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
