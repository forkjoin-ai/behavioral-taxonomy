(loop_373_start: BehaviorStart { loopId: 373, loopName: 'The%20Pocket%20Hands%20Loop', given: 'Hands%20permanently%20concealed%20in%20pockets', when: 'talking', then: 'observers%20feel%20%22Unease%22%20(The%20Concealment%20Operator)', result: 'the%20individual%20being%20seen%20as%20having%20something%20to%20hide', operatorName: 'The%20Concealment%20Operator', operatorMechanism: 'observers%20feel%20%22Unease%22', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20touch%20aversion%20or%20seeking%20behaviors', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
(loop_373_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'SUBMISSION' })
(loop_373_then_branch: BehaviorEmit { emission: 'then', text: 'observers%20feel%20%22Unease%22%20(The%20Concealment%20Operator)' })
(loop_373_verdict: BehaviorVerdict { loopId: 373, loopName: 'The%20Pocket%20Hands%20Loop', then: 'observers%20feel%20%22Unease%22%20(The%20Concealment%20Operator)', result: 'the%20individual%20being%20seen%20as%20having%20something%20to%20hide', operatorName: 'The%20Concealment%20Operator', operatorMechanism: 'observers%20feel%20%22Unease%22', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'SUBMISSION' })
