(loop_373_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_373_inactive)
(loop_373_context)-[:FORK { strategy: "behavior-branches" }]->(loop_373_context_branch | loop_373_then_branch | loop_373_operator_branch | loop_373_result_branch | loop_373_taxonomy_branch | loop_373_intervention_recognize | loop_373_intervention_interdict | loop_373_intervention_minimize)
(loop_373_context_branch | loop_373_then_branch | loop_373_operator_branch | loop_373_result_branch | loop_373_taxonomy_branch | loop_373_intervention_recognize | loop_373_intervention_interdict | loop_373_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_373_verdict)
(loop_373_inactive)-[:PROCESS]->(loop_373_sink)
(loop_373_verdict)-[:PROCESS]->(loop_373_sink)
(loop_373_verdict)-[:MEASURE]->(loop_373_sink)
