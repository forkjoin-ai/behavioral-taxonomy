// Topology
(loop_373_start)-[:PROCESS]->(loop_373_given_gate)
(loop_373_given_gate)-[:PROCESS { case: "ok" }]->(loop_373_when_gate)
(loop_373_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_373_inactive)
