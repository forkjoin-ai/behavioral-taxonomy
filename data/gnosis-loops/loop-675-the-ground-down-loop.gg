(loop_675_inactive: BehaviorTerminal { loopId: 675, loopName: 'The%20Ground%20Down%20Loop' })
(loop_675_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
(loop_675_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_675_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong' })
(loop_675_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Stress%20Operator', mechanism: 'the%20teeth%20look%20%22Stubby%22%20or%20%22Intense%22' })
(loop_675_result_branch: BehaviorEmit { emission: 'result', text: 'observers%20assuming%20the%20individual%20is%20%22High%20Strung%22%20or%20%22Aggressive.%22' })
(loop_675_sink: BehaviorSink)
(loop_675_start: BehaviorStart { loopId: 675, loopName: 'The%20Ground%20Down%20Loop', given: 'Short%2C%20flat%20teeth%20from%20grinding', when: 'talking', then: 'the%20teeth%20look%20%22Stubby%22%20or%20%22Intense%22%20(The%20Stress%20Operator)', result: 'observers%20assuming%20the%20individual%20is%20%22High%20Strung%22%20or%20%22Aggressive.%22', operatorName: 'The%20Stress%20Operator', operatorMechanism: 'the%20teeth%20look%20%22Stubby%22%20or%20%22Intense%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_675_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_675_then_branch: BehaviorEmit { emission: 'then', text: 'the%20teeth%20look%20%22Stubby%22%20or%20%22Intense%22%20(The%20Stress%20Operator)' })
(loop_675_verdict: BehaviorVerdict { loopId: 675, loopName: 'The%20Ground%20Down%20Loop', then: 'the%20teeth%20look%20%22Stubby%22%20or%20%22Intense%22%20(The%20Stress%20Operator)', result: 'observers%20assuming%20the%20individual%20is%20%22High%20Strung%22%20or%20%22Aggressive.%22', operatorName: 'The%20Stress%20Operator', operatorMechanism: 'the%20teeth%20look%20%22Stubby%22%20or%20%22Intense%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_675_when_gate: BehaviorAssess { stage: 'when', text: 'talking' })

// Topology
(loop_675_start)-[:PROCESS]->(loop_675_given_gate)
(loop_675_given_gate)-[:PROCESS { case: "ok" }]->(loop_675_when_gate)
(loop_675_given_gate)-[:PROCESS { case: "err" }]->(loop_675_inactive)
(loop_675_when_gate)-[:PROCESS { case: "ok" }]->(loop_675_context)
(loop_675_when_gate)-[:PROCESS { case: "err" }]->(loop_675_inactive)
(loop_675_context)-[:FORK { strategy: "behavior-branches" }]->(loop_675_context_branch | loop_675_then_branch | loop_675_operator_branch | loop_675_result_branch | loop_675_taxonomy_branch | loop_675_intervention_recognize | loop_675_intervention_interdict | loop_675_intervention_minimize)
(loop_675_context_branch | loop_675_then_branch | loop_675_operator_branch | loop_675_result_branch | loop_675_taxonomy_branch | loop_675_intervention_recognize | loop_675_intervention_interdict | loop_675_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_675_verdict)
(loop_675_inactive)-[:PROCESS]->(loop_675_sink)
(loop_675_verdict)-[:PROCESS]->(loop_675_sink)
(loop_675_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_675_then_branch)
(loop_675_intervention_interdict)-[:INTERFERE { mode: "destructive" }]->(loop_675_then_branch)
(loop_675_intervention_minimize)-[:INTERFERE { mode: "destructive" }]->(loop_675_then_branch)