(loop_813_context)-[:FORK { strategy: "behavior-branches" }]->(loop_813_context_branch | loop_813_then_branch | loop_813_operator_branch | loop_813_result_branch | loop_813_taxonomy_branch | loop_813_intervention_recognize | loop_813_intervention_leverage)
(loop_813_context_branch | loop_813_then_branch | loop_813_operator_branch | loop_813_result_branch | loop_813_taxonomy_branch | loop_813_intervention_recognize | loop_813_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_813_verdict)
(loop_813_inactive)-[:PROCESS]->(loop_813_sink)
