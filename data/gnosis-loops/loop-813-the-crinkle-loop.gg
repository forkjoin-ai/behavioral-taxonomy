(loop_813_start: BehaviorStart { loopId: 813, loopName: 'The%20Crinkle%20Loop', given: "Activation%20of%20Orbicularis%20Oculi%20(crow's%20feet)%20when%20smiling", when: 'greeting', then: 'the%20smile%20registers%20as%20%22Authentic%22%20(The%20Joy%20Operator)', result: 'immediate%20trust%20and%20reciprocal%20smiling', operatorName: 'The%20Joy%20Operator', operatorMechanism: 'the%20smile%20registers%20as%20%22Authentic%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'TRUST', interventionDifficulty: '8', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_leverage: 'Use%20in%20high-stakes%20negotiations%20and%20first%20impressions' })
