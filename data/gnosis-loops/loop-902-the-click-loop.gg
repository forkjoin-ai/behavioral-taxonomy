// behavioral-loop-902.gg
// Executable Gnosis projection for The Click Loop.

// Nodes
(loop_902_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_902_context_branch: BehaviorEmit { emission: 'context' })
(loop_902_given_gate: BehaviorAssess { stage: 'given', text: 'Jaw%20joint%20displacement' })
(loop_902_inactive: BehaviorTerminal { loopId: 902, loopName: 'The%20Click%20Loop' })
(loop_902_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
(loop_902_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_902_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Watch%20for%20snap%20judgments%20based%20on%20appearance' })
(loop_902_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Joint%20Operator', mechanism: 'a%20loud%20*pop*%20is%20heard' })
(loop_902_result_branch: BehaviorEmit { emission: 'result', text: 'dining%20partners%20losing%20their%20appetite%20or%20wincing' })
(loop_902_sink: BehaviorSink)
(loop_902_start: BehaviorStart { loopId: 902, loopName: 'The%20Click%20Loop', given: 'Jaw%20joint%20displacement', when: 'chewing%20or%20yawning', then: 'a%20loud%20*pop*%20is%20heard%20(The%20Joint%20Operator)', result: 'dining%20partners%20losing%20their%20appetite%20or%20wincing', operatorName: 'The%20Joint%20Operator', operatorMechanism: 'a%20loud%20*pop*%20is%20heard', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '5', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_902_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_902_then_branch: BehaviorEmit { emission: 'then', text: 'a%20loud%20*pop*%20is%20heard%20(The%20Joint%20Operator)' })
(loop_902_verdict: BehaviorVerdict { loopId: 902, loopName: 'The%20Click%20Loop', then: 'a%20loud%20*pop*%20is%20heard%20(The%20Joint%20Operator)', result: 'dining%20partners%20losing%20their%20appetite%20or%20wincing', operatorName: 'The%20Joint%20Operator', operatorMechanism: 'a%20loud%20*pop*%20is%20heard', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_902_when_gate: BehaviorAssess { stage: 'when', text: 'chewing%20or%20yawning' })

// Topology
(loop_902_start)-[:PROCESS]->(loop_902_given_gate)
(loop_902_given_gate)-[:PROCESS { case: "ok" }]->(loop_902_when_gate)
(loop_902_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_902_inactive)
(loop_902_when_gate)-[:PROCESS { case: "ok" }]->(loop_902_context)
(loop_902_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_902_inactive)
(loop_902_context)-[:FORK { strategy: "behavior-branches" }]->(loop_902_context_branch | loop_902_then_branch | loop_902_operator_branch | loop_902_result_branch | loop_902_taxonomy_branch | loop_902_intervention_recognize | loop_902_intervention_interdict | loop_902_intervention_minimize)
(loop_902_context_branch | loop_902_then_branch | loop_902_operator_branch | loop_902_result_branch | loop_902_taxonomy_branch | loop_902_intervention_recognize | loop_902_intervention_interdict | loop_902_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_902_verdict)
(loop_902_inactive)-[:PROCESS]->(loop_902_sink)
(loop_902_verdict)-[:PROCESS]->(loop_902_sink)
(loop_902_verdict)-[:MEASURE]->(loop_902_sink)
(loop_902_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_902_then_branch)
(loop_902_intervention_interdict)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_902_then_branch)
(loop_902_intervention_minimize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_902_then_branch)