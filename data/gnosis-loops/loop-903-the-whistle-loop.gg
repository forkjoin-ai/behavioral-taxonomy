(loop_903_given_gate: BehaviorAssess { stage: 'given', text: 'Dried%20mucus%20or%20polyp%20in%20the%20nose' })
(loop_903_inactive: BehaviorTerminal { loopId: 903, loopName: 'The%20Whistle%20Loop' })
(loop_903_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
(loop_903_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_903_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Watch%20for%20snap%20judgments%20based%20on%20appearance' })
