(loop_903_result_branch: BehaviorEmit { emission: 'result', text: 'others%20checking%20their%20phones%2Felectronics%20for%20the%20source%20of%20the%20noise' })
(loop_903_sink: BehaviorSink)
(loop_903_start: BehaviorStart { loopId: 903, loopName: 'The%20Whistle%20Loop', given: 'Dried%20mucus%20or%20polyp%20in%20the%20nose', when: 'breathing%20quietly', then: 'a%20high-pitched%20tone%20is%20emitted%20(The%20Kettle%20Operator)', result: 'others%20checking%20their%20phones%2Felectronics%20for%20the%20source%20of%20the%20noise', operatorName: 'The%20Kettle%20Operator', operatorMechanism: 'a%20high-pitched%20tone%20is%20emitted', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_903_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_903_then_branch: BehaviorEmit { emission: 'then', text: 'a%20high-pitched%20tone%20is%20emitted%20(The%20Kettle%20Operator)' })
(loop_903_verdict: BehaviorVerdict { loopId: 903, loopName: 'The%20Whistle%20Loop', then: 'a%20high-pitched%20tone%20is%20emitted%20(The%20Kettle%20Operator)', result: 'others%20checking%20their%20phones%2Felectronics%20for%20the%20source%20of%20the%20noise', operatorName: 'The%20Kettle%20Operator', operatorMechanism: 'a%20high-pitched%20tone%20is%20emitted', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_903_when_gate: BehaviorAssess { stage: 'when', text: 'breathing%20quietly' })

// Topology
(loop_903_start)-[:PROCESS]->(loop_903_given_gate)
(loop_903_given_gate)-[:PROCESS { case: "ok" }]->(loop_903_when_gate)
(loop_903_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_903_inactive)
(loop_903_when_gate)-[:PROCESS { case: "ok" }]->(loop_903_context)
(loop_903_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_903_inactive)
(loop_903_context)-[:FORK { strategy: "behavior-branches" }]->(loop_903_context_branch | loop_903_then_branch | loop_903_operator_branch | loop_903_result_branch | loop_903_taxonomy_branch | loop_903_intervention_recognize | loop_903_intervention_interdict | loop_903_intervention_minimize)
(loop_903_context_branch | loop_903_then_branch | loop_903_operator_branch | loop_903_result_branch | loop_903_taxonomy_branch | loop_903_intervention_recognize | loop_903_intervention_interdict | loop_903_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_903_verdict)
(loop_903_inactive)-[:PROCESS]->(loop_903_sink)
(loop_903_verdict)-[:PROCESS]->(loop_903_sink)
(loop_903_verdict)-[:MEASURE]->(loop_903_sink)
(loop_903_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_903_then_branch)
(loop_903_intervention_interdict)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_903_then_branch)
(loop_903_intervention_minimize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_903_then_branch)