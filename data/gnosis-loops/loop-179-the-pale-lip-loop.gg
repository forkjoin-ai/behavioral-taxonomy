(loop_179_start: BehaviorStart { loopId: 179, loopName: 'The%20Pale%20Lip%20Loop', given: 'Low%20hemoglobin%20or%20vascularity%20in%20vermilion', when: 'resting', then: 'the%20face%20looks%20%22Sickly%22%20or%20%22Anemic%22%20(The%20Pity%20Operator)', result: 'constant%20inquiries%20of%20%22Are%20you%20okay%3F%22%2C%20leading%20to%20**Irritability**', operatorName: 'The%20Pity%20Operator', operatorMechanism: 'the%20face%20looks%20%22Sickly%22%20or%20%22Anemic%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '5', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
