(loop_271_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Stereotype%20Operator', mechanism: 'older%20observers%20perceive%20%22Valley%20Girl%22%20or%20%22Lack%20of%20Gravitas%22' })
(loop_271_result_branch: BehaviorEmit { emission: 'result', text: 'the%20content%20of%20the%20speech%20being%20**Discounted**' })
