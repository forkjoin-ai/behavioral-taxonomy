(loop_998_given_gate: BehaviorAssess { stage: 'given', text: "Asthmatic%20or%20smoker's%20lungs" })
(loop_998_inactive: BehaviorTerminal { loopId: 998, loopName: 'The%20Wheeze%20Loop' })
(loop_998_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
