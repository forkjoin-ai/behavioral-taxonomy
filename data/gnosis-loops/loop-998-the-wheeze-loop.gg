(loop_998_sink: BehaviorSink)
(loop_998_start: BehaviorStart { loopId: 998, loopName: 'The%20Wheeze%20Loop', given: "Asthmatic%20or%20smoker's%20lungs", when: 'laughing%20hard', then: 'sound%20vanishes%20into%20a%20silent%2C%20gasping%20rattle%20(The%20Muttley%20Operator)', result: 'the%20group%20worrying%20the%20individual%20is%20choking', operatorName: 'The%20Muttley%20Operator', operatorMechanism: 'sound%20vanishes%20into%20a%20silent%2C%20gasping%20rattle', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
(loop_998_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_998_then_branch: BehaviorEmit { emission: 'then', text: 'sound%20vanishes%20into%20a%20silent%2C%20gasping%20rattle%20(The%20Muttley%20Operator)' })
(loop_998_verdict: BehaviorVerdict { loopId: 998, loopName: 'The%20Wheeze%20Loop', then: 'sound%20vanishes%20into%20a%20silent%2C%20gasping%20rattle%20(The%20Muttley%20Operator)', result: 'the%20group%20worrying%20the%20individual%20is%20choking', operatorName: 'The%20Muttley%20Operator', operatorMechanism: 'sound%20vanishes%20into%20a%20silent%2C%20gasping%20rattle', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_998_when_gate: BehaviorAssess { stage: 'when', text: 'laughing%20hard' })

// Topology
(loop_998_start)-[:PROCESS]->(loop_998_given_gate)
(loop_998_given_gate)-[:PROCESS { case: "ok" }]->(loop_998_when_gate)
(loop_998_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_998_inactive)
