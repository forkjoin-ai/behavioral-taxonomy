(loop_998_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_998_inactive)
(loop_998_context)-[:FORK { strategy: "behavior-branches" }]->(loop_998_context_branch | loop_998_then_branch | loop_998_operator_branch | loop_998_result_branch | loop_998_taxonomy_branch | loop_998_intervention_recognize | loop_998_intervention_interdict | loop_998_intervention_minimize)
(loop_998_context_branch | loop_998_then_branch | loop_998_operator_branch | loop_998_result_branch | loop_998_taxonomy_branch | loop_998_intervention_recognize | loop_998_intervention_interdict | loop_998_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_998_verdict)
(loop_998_inactive)-[:PROCESS]->(loop_998_sink)
(loop_998_verdict)-[:PROCESS]->(loop_998_sink)
(loop_998_verdict)-[:MEASURE]->(loop_998_sink)
