(loop_8003_given_gate: BehaviorAssess { stage: 'given', text: 'A%20negative%20event%20happens%20to%20Someone%20Else' })
(loop_8003_inactive: BehaviorTerminal { loopId: 8003, loopName: 'The%20Fundamental%20Attribution%20Loop' })
(loop_8003_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
