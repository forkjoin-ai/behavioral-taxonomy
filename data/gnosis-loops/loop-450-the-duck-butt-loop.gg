(loop_450_start: BehaviorStart { loopId: 450, loopName: 'The%20Duck%20Butt%20Loop', given: 'Tight%20hip%20flexors%20causing%20lumbar%20arching', when: 'standing%20normally', then: 'the%20abdomen%20protrudes%20and%20buttocks%20stick%20out%20(The%20Posturing%20Operator)', result: 'back%20pain%20and%20observers%20assuming%20the%20individual%20is%20%22trying%20too%20hard%22%20to%20be%20sexy%20(female)%20or%20has%20a%20gut%20(male)', operatorName: 'The%20Posturing%20Operator', operatorMechanism: 'the%20abdomen%20protrudes%20and%20buttocks%20stick%20out', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
