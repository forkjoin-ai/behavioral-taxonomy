(loop_450_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_450_inactive)
(loop_450_context)-[:FORK { strategy: "behavior-branches" }]->(loop_450_context_branch | loop_450_then_branch | loop_450_operator_branch | loop_450_result_branch | loop_450_taxonomy_branch | loop_450_intervention_recognize | loop_450_intervention_interdict | loop_450_intervention_minimize)
(loop_450_context_branch | loop_450_then_branch | loop_450_operator_branch | loop_450_result_branch | loop_450_taxonomy_branch | loop_450_intervention_recognize | loop_450_intervention_interdict | loop_450_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_450_verdict)
