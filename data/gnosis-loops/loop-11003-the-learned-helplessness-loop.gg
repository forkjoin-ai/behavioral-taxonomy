(loop_11003_context)-[:FORK { strategy: "behavior-branches" }]->(loop_11003_context_branch | loop_11003_then_branch | loop_11003_operator_branch | loop_11003_result_branch | loop_11003_taxonomy_branch | loop_11003_intervention_recognize | loop_11003_intervention_interdict | loop_11003_intervention_minimize)
(loop_11003_context_branch | loop_11003_then_branch | loop_11003_operator_branch | loop_11003_result_branch | loop_11003_taxonomy_branch | loop_11003_intervention_recognize | loop_11003_intervention_interdict | loop_11003_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_11003_verdict)
