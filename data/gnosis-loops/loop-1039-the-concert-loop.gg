(loop_1039_sink: BehaviorSink)
(loop_1039_start: BehaviorStart { loopId: 1039, loopName: 'The%20Concert%20Loop', given: 'Group%20synchronization', when: 'the%20beat%20drops', then: 'the%20individual%20loses%20autonomy%20and%20moves%20as%20a%20fluid%20(The%20Hive%20Mind)', result: '%22post-concert%20amnesia%22%20where%20the%20event%20is%20felt%20but%20not%20remembered', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20individual%20loses%20autonomy%20and%20moves%20as%20a%20fluid%20(The%20Hive%20Mind)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_1039_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1039_then_branch: BehaviorEmit { emission: 'then', text: 'the%20individual%20loses%20autonomy%20and%20moves%20as%20a%20fluid%20(The%20Hive%20Mind)' })
(loop_1039_verdict: BehaviorVerdict { loopId: 1039, loopName: 'The%20Concert%20Loop', then: 'the%20individual%20loses%20autonomy%20and%20moves%20as%20a%20fluid%20(The%20Hive%20Mind)', result: '%22post-concert%20amnesia%22%20where%20the%20event%20is%20felt%20but%20not%20remembered', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20individual%20loses%20autonomy%20and%20moves%20as%20a%20fluid%20(The%20Hive%20Mind)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1039_when_gate: BehaviorAssess { stage: 'when', text: 'the%20beat%20drops' })

// Topology
(loop_1039_start)-[:PROCESS]->(loop_1039_given_gate)
(loop_1039_given_gate)-[:PROCESS { case: "ok" }]->(loop_1039_when_gate)
(loop_1039_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_1039_inactive)
(loop_1039_when_gate)-[:PROCESS { case: "ok" }]->(loop_1039_context)
(loop_1039_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_1039_inactive)
(loop_1039_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1039_context_branch | loop_1039_then_branch | loop_1039_operator_branch | loop_1039_result_branch | loop_1039_taxonomy_branch | loop_1039_intervention_recognize | loop_1039_intervention_interdict | loop_1039_intervention_minimize)
(loop_1039_context_branch | loop_1039_then_branch | loop_1039_operator_branch | loop_1039_result_branch | loop_1039_taxonomy_branch | loop_1039_intervention_recognize | loop_1039_intervention_interdict | loop_1039_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1039_verdict)
(loop_1039_inactive)-[:PROCESS]->(loop_1039_sink)
