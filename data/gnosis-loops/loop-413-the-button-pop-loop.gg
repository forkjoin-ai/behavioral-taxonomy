// Topology
(loop_413_start)-[:PROCESS]->(loop_413_given_gate)
(loop_413_given_gate)-[:PROCESS { case: "ok" }]->(loop_413_when_gate)
(loop_413_given_gate)-[:PROCESS { case: "err" }]->(loop_413_inactive)
(loop_413_when_gate)-[:PROCESS { case: "ok" }]->(loop_413_context)
(loop_413_when_gate)-[:PROCESS { case: "err" }]->(loop_413_inactive)
(loop_413_context)-[:FORK { strategy: "behavior-branches" }]->(loop_413_context_branch | loop_413_then_branch | loop_413_operator_branch | loop_413_result_branch | loop_413_taxonomy_branch | loop_413_intervention_recognize | loop_413_intervention_interdict | loop_413_intervention_minimize)
(loop_413_context_branch | loop_413_then_branch | loop_413_operator_branch | loop_413_result_branch | loop_413_taxonomy_branch | loop_413_intervention_recognize | loop_413_intervention_interdict | loop_413_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_413_verdict)
(loop_413_inactive)-[:PROCESS]->(loop_413_sink)
(loop_413_verdict)-[:PROCESS]->(loop_413_sink)
(loop_413_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_413_then_branch)
