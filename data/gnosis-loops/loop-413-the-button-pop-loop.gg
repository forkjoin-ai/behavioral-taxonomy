(loop_413_inactive: BehaviorTerminal { loopId: 413, loopName: 'The%20Button%20Pop%20Loop' })
(loop_413_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
