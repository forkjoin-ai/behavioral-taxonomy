(loop_704_inactive: BehaviorTerminal { loopId: 704, loopName: 'The%20Pale%20Ghost%20Loop' })
(loop_704_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
