(loop_553_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_553_inactive)
(loop_553_context)-[:FORK { strategy: "behavior-branches" }]->(loop_553_context_branch | loop_553_then_branch | loop_553_operator_branch | loop_553_result_branch | loop_553_taxonomy_branch | loop_553_intervention_recognize | loop_553_intervention_interdict | loop_553_intervention_minimize)
(loop_553_context_branch | loop_553_then_branch | loop_553_operator_branch | loop_553_result_branch | loop_553_taxonomy_branch | loop_553_intervention_recognize | loop_553_intervention_interdict | loop_553_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_553_verdict)
(loop_553_inactive)-[:PROCESS]->(loop_553_sink)
