(loop_713_start: BehaviorStart { loopId: 713, loopName: 'The%20Furnace%20Loop', given: 'Radiating%20heat%20from%20palms', when: 'shaking%20hands', then: 'the%20recipient%20feels%20%22Feverish%22%20or%20%22Intense%22%20(The%20Infection%20Operator)', result: 'a%20quick%20release%20of%20the%20grip', operatorName: 'The%20Infection%20Operator', operatorMechanism: 'the%20recipient%20feels%20%22Feverish%22%20or%20%22Intense%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Seek%20feedback%20from%20trusted%20allies%20about%20perception%20gaps' })
(loop_713_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_713_then_branch: BehaviorEmit { emission: 'then', text: 'the%20recipient%20feels%20%22Feverish%22%20or%20%22Intense%22%20(The%20Infection%20Operator)' })
(loop_713_verdict: BehaviorVerdict { loopId: 713, loopName: 'The%20Furnace%20Loop', then: 'the%20recipient%20feels%20%22Feverish%22%20or%20%22Intense%22%20(The%20Infection%20Operator)', result: 'a%20quick%20release%20of%20the%20grip', operatorName: 'The%20Infection%20Operator', operatorMechanism: 'the%20recipient%20feels%20%22Feverish%22%20or%20%22Intense%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
