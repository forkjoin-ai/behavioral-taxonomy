(loop_713_inactive: BehaviorTerminal { loopId: 713, loopName: 'The%20Furnace%20Loop' })
(loop_713_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
