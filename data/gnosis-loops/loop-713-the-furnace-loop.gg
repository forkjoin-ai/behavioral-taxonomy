(loop_713_context)-[:FORK { strategy: "behavior-branches" }]->(loop_713_context_branch | loop_713_then_branch | loop_713_operator_branch | loop_713_result_branch | loop_713_taxonomy_branch | loop_713_intervention_recognize | loop_713_intervention_interdict | loop_713_intervention_minimize)
