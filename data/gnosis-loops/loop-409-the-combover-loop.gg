(loop_409_context)-[:FORK { strategy: "behavior-branches" }]->(loop_409_context_branch | loop_409_then_branch | loop_409_operator_branch | loop_409_result_branch | loop_409_taxonomy_branch | loop_409_intervention_recognize | loop_409_intervention_interdict | loop_409_intervention_minimize)
(loop_409_context_branch | loop_409_then_branch | loop_409_operator_branch | loop_409_result_branch | loop_409_taxonomy_branch | loop_409_intervention_recognize | loop_409_intervention_interdict | loop_409_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_409_verdict)
