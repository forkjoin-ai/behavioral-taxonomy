(loop_803_context)-[:FORK { strategy: "behavior-branches" }]->(loop_803_context_branch | loop_803_then_branch | loop_803_operator_branch | loop_803_result_branch | loop_803_taxonomy_branch | loop_803_intervention_recognize | loop_803_intervention_interdict | loop_803_intervention_minimize | loop_803_intervention_leverage)
(loop_803_context_branch | loop_803_then_branch | loop_803_operator_branch | loop_803_result_branch | loop_803_taxonomy_branch | loop_803_intervention_recognize | loop_803_intervention_interdict | loop_803_intervention_minimize | loop_803_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_803_verdict)
(loop_803_inactive)-[:PROCESS]->(loop_803_sink)
