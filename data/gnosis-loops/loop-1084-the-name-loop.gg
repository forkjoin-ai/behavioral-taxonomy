(loop_1084_context_branch | loop_1084_then_branch | loop_1084_operator_branch | loop_1084_result_branch | loop_1084_taxonomy_branch | loop_1084_intervention_recognize | loop_1084_intervention_interdict | loop_1084_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1084_verdict)
