// behavioral-loop-595.gg
// Executable Gnosis projection for The Rudolph Loop.

// Nodes
(loop_595_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_595_context_branch: BehaviorEmit { emission: 'context' })
(loop_595_given_gate: BehaviorAssess { stage: 'given', text: 'Red%2C%20bulbous%20nose%20tip' })
(loop_595_inactive: BehaviorTerminal { loopId: 595, loopName: 'The%20Rudolph%20Loop' })
(loop_595_intervention_leverage: BehaviorEmit { emission: 'intervention', interventionKind: 'leverage', text: 'Use%20in%20high-stakes%20negotiations%20and%20first%20impressions' })
