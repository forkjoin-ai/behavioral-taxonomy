(loop_147_context)-[:FORK { strategy: "behavior-branches" }]->(loop_147_context_branch | loop_147_then_branch | loop_147_operator_branch | loop_147_result_branch | loop_147_taxonomy_branch | loop_147_intervention_recognize | loop_147_intervention_interdict | loop_147_intervention_minimize)
(loop_147_context_branch | loop_147_then_branch | loop_147_operator_branch | loop_147_result_branch | loop_147_taxonomy_branch | loop_147_intervention_recognize | loop_147_intervention_interdict | loop_147_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_147_verdict)
(loop_147_inactive)-[:PROCESS]->(loop_147_sink)
