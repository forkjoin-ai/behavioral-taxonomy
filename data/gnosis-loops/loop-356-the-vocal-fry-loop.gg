(loop_356_verdict: BehaviorVerdict { loopId: 356, loopName: 'The%20Vocal%20Fry%20Loop', then: 'listeners%20perceive%20%22Relaxed%20Confidence%22%20or%20%22Expertise%22%20(The%20Guru%20Operator)', result: 'the%20opposite%20effect%20of%20female%20vocal%20fry%20(where%20it%20signals%20incompetence)', operatorName: 'The%20Guru%20Operator', operatorMechanism: 'listeners%20perceive%20%22Relaxed%20Confidence%22%20or%20%22Expertise%22', origin: 'BEHAVIORAL', modality: 'AUDITORY', mutability: '1', valences: 'SUBMISSION' })
