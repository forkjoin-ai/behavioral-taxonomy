(loop_356_context)-[:FORK { strategy: "behavior-branches" }]->(loop_356_context_branch | loop_356_then_branch | loop_356_operator_branch | loop_356_result_branch | loop_356_taxonomy_branch | loop_356_intervention_recognize | loop_356_intervention_interdict | loop_356_intervention_minimize)
(loop_356_context_branch | loop_356_then_branch | loop_356_operator_branch | loop_356_result_branch | loop_356_taxonomy_branch | loop_356_intervention_recognize | loop_356_intervention_interdict | loop_356_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_356_verdict)
