(loop_293_context)-[:FORK { strategy: "behavior-branches" }]->(loop_293_context_branch | loop_293_then_branch | loop_293_operator_branch | loop_293_result_branch | loop_293_taxonomy_branch | loop_293_intervention_recognize | loop_293_intervention_interdict | loop_293_intervention_minimize)
(loop_293_context_branch | loop_293_then_branch | loop_293_operator_branch | loop_293_result_branch | loop_293_taxonomy_branch | loop_293_intervention_recognize | loop_293_intervention_interdict | loop_293_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_293_verdict)
(loop_293_inactive)-[:PROCESS]->(loop_293_sink)
(loop_293_verdict)-[:PROCESS]->(loop_293_sink)
(loop_293_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_293_then_branch)
