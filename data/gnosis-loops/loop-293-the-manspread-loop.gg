(loop_293_start: BehaviorStart { loopId: 293, loopName: 'The%20Manspread%20Loop', given: 'Structural%20hip%20socket%20angle%20favoring%20abduction', when: 'sitting%20on%20transit%20or%20benches', then: 'the%20individual%20consumes%20adjacent%20space%20(The%20Dominance%2FRude%20Operator)', result: 'peers%20physically%20shrinking%20away%2C%20reinforcing%20a%20**Territorial%20Self-Concept**', operatorName: 'The%20Dominance%2FRude%20Operator', operatorMechanism: 'the%20individual%20consumes%20adjacent%20space', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_293_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_293_then_branch: BehaviorEmit { emission: 'then', text: 'the%20individual%20consumes%20adjacent%20space%20(The%20Dominance%2FRude%20Operator)' })
(loop_293_verdict: BehaviorVerdict { loopId: 293, loopName: 'The%20Manspread%20Loop', then: 'the%20individual%20consumes%20adjacent%20space%20(The%20Dominance%2FRude%20Operator)', result: 'peers%20physically%20shrinking%20away%2C%20reinforcing%20a%20**Territorial%20Self-Concept**', operatorName: 'The%20Dominance%2FRude%20Operator', operatorMechanism: 'the%20individual%20consumes%20adjacent%20space', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
