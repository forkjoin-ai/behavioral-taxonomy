(loop_572_start: BehaviorStart { loopId: 572, loopName: 'The%20Slope%20Shoulder%20Loop', given: 'Low%20clavicular%20angle%20(drooping%20shoulders)', when: 'wearing%20a%20jacket', then: 'the%20fit%20is%20poor%20and%20posture%20looks%20%22Sad%22%20(The%20Eeyore%20Operator)', result: "being%20asked%20%22What's%20wrong%3F%22%20when%20fine", operatorName: 'The%20Eeyore%20Operator', operatorMechanism: 'the%20fit%20is%20poor%20and%20posture%20looks%20%22Sad%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
(loop_572_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
