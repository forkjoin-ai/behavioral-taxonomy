(loop_572_context)-[:FORK { strategy: "behavior-branches" }]->(loop_572_context_branch | loop_572_then_branch | loop_572_operator_branch | loop_572_result_branch | loop_572_taxonomy_branch | loop_572_intervention_recognize | loop_572_intervention_interdict | loop_572_intervention_minimize)
(loop_572_context_branch | loop_572_then_branch | loop_572_operator_branch | loop_572_result_branch | loop_572_taxonomy_branch | loop_572_intervention_recognize | loop_572_intervention_interdict | loop_572_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_572_verdict)
(loop_572_inactive)-[:PROCESS]->(loop_572_sink)
