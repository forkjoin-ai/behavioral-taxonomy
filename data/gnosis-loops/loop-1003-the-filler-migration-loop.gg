(loop_1003_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_1003_inactive)
(loop_1003_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1003_context_branch | loop_1003_then_branch | loop_1003_operator_branch | loop_1003_result_branch | loop_1003_taxonomy_branch | loop_1003_intervention_recognize | loop_1003_intervention_interdict | loop_1003_intervention_minimize)
(loop_1003_context_branch | loop_1003_then_branch | loop_1003_operator_branch | loop_1003_result_branch | loop_1003_taxonomy_branch | loop_1003_intervention_recognize | loop_1003_intervention_interdict | loop_1003_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1003_verdict)
(loop_1003_inactive)-[:PROCESS]->(loop_1003_sink)
