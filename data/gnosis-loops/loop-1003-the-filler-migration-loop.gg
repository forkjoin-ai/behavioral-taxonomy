(loop_1003_start: BehaviorStart { loopId: 1003, loopName: 'The%20Filler%20Migration%20Loop', given: 'Hyaluronic%20acid%20spreading%20above%20the%20vermilion%20border', when: 'in%20profile', then: 'the%20lip%20looks%20like%20a%20%22Beak%22%20or%20%22Shelf%22%20(The%20Platypus%20Operator)', result: 'ridicule%20and%20assumptions%20of%20body%20dysmorphia', operatorName: 'The%20Platypus%20Operator', operatorMechanism: 'the%20lip%20looks%20like%20a%20%22Beak%22%20or%20%22Shelf%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
(loop_1003_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1003_then_branch: BehaviorEmit { emission: 'then', text: 'the%20lip%20looks%20like%20a%20%22Beak%22%20or%20%22Shelf%22%20(The%20Platypus%20Operator)' })
(loop_1003_verdict: BehaviorVerdict { loopId: 1003, loopName: 'The%20Filler%20Migration%20Loop', then: 'the%20lip%20looks%20like%20a%20%22Beak%22%20or%20%22Shelf%22%20(The%20Platypus%20Operator)', result: 'ridicule%20and%20assumptions%20of%20body%20dysmorphia', operatorName: 'The%20Platypus%20Operator', operatorMechanism: 'the%20lip%20looks%20like%20a%20%22Beak%22%20or%20%22Shelf%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1003_when_gate: BehaviorAssess { stage: 'when', text: 'in%20profile' })

// Topology
(loop_1003_start)-[:PROCESS]->(loop_1003_given_gate)
(loop_1003_given_gate)-[:PROCESS { case: "ok" }]->(loop_1003_when_gate)
(loop_1003_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_1003_inactive)
