(loop_843_context)-[:FORK { strategy: "behavior-branches" }]->(loop_843_context_branch | loop_843_then_branch | loop_843_operator_branch | loop_843_result_branch | loop_843_taxonomy_branch | loop_843_intervention_recognize | loop_843_intervention_interdict | loop_843_intervention_minimize)
