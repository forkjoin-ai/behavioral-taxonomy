(loop_843_inactive)-[:PROCESS]->(loop_843_sink)
(loop_843_verdict)-[:PROCESS]->(loop_843_sink)
(loop_843_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_843_then_branch)
