(loop_294_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_294_inactive)
(loop_294_context)-[:FORK { strategy: "behavior-branches" }]->(loop_294_context_branch | loop_294_then_branch | loop_294_operator_branch | loop_294_result_branch | loop_294_taxonomy_branch | loop_294_intervention_recognize | loop_294_intervention_interdict | loop_294_intervention_minimize)
(loop_294_context_branch | loop_294_then_branch | loop_294_operator_branch | loop_294_result_branch | loop_294_taxonomy_branch | loop_294_intervention_recognize | loop_294_intervention_interdict | loop_294_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_294_verdict)
(loop_294_inactive)-[:PROCESS]->(loop_294_sink)
