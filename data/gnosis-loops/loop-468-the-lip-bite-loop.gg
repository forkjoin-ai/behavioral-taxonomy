(loop_468_context)-[:FORK { strategy: "behavior-branches" }]->(loop_468_context_branch | loop_468_then_branch | loop_468_operator_branch | loop_468_result_branch | loop_468_taxonomy_branch | loop_468_intervention_recognize | loop_468_intervention_interdict | loop_468_intervention_minimize)
(loop_468_context_branch | loop_468_then_branch | loop_468_operator_branch | loop_468_result_branch | loop_468_taxonomy_branch | loop_468_intervention_recognize | loop_468_intervention_interdict | loop_468_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_468_verdict)
(loop_468_inactive)-[:PROCESS]->(loop_468_sink)
