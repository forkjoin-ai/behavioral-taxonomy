// Topology
(loop_116_start)-[:PROCESS]->(loop_116_given_gate)
(loop_116_given_gate)-[:PROCESS { case: "ok" }]->(loop_116_when_gate)
(loop_116_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_116_inactive)
(loop_116_when_gate)-[:PROCESS { case: "ok" }]->(loop_116_context)
(loop_116_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_116_inactive)
(loop_116_context)-[:FORK { strategy: "behavior-branches" }]->(loop_116_context_branch | loop_116_then_branch | loop_116_operator_branch | loop_116_result_branch | loop_116_taxonomy_branch | loop_116_intervention_recognize | loop_116_intervention_interdict | loop_116_intervention_minimize)
(loop_116_context_branch | loop_116_then_branch | loop_116_operator_branch | loop_116_result_branch | loop_116_taxonomy_branch | loop_116_intervention_recognize | loop_116_intervention_interdict | loop_116_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_116_verdict)
(loop_116_inactive)-[:PROCESS]->(loop_116_sink)
(loop_116_verdict)-[:PROCESS]->(loop_116_sink)
