// Topology
(loop_212_start)-[:PROCESS]->(loop_212_given_gate)
(loop_212_given_gate)-[:PROCESS { case: "ok" }]->(loop_212_when_gate)
(loop_212_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_212_inactive)
