(loop_212_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_212_inactive)
(loop_212_context)-[:FORK { strategy: "behavior-branches" }]->(loop_212_context_branch | loop_212_then_branch | loop_212_operator_branch | loop_212_result_branch | loop_212_taxonomy_branch | loop_212_intervention_recognize | loop_212_intervention_interdict | loop_212_intervention_minimize)
(loop_212_context_branch | loop_212_then_branch | loop_212_operator_branch | loop_212_result_branch | loop_212_taxonomy_branch | loop_212_intervention_recognize | loop_212_intervention_interdict | loop_212_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_212_verdict)
(loop_212_inactive)-[:PROCESS]->(loop_212_sink)
(loop_212_verdict)-[:PROCESS]->(loop_212_sink)
