(loop_178_context)-[:FORK { strategy: "behavior-branches" }]->(loop_178_context_branch | loop_178_then_branch | loop_178_operator_branch | loop_178_result_branch | loop_178_taxonomy_branch | loop_178_intervention_recognize | loop_178_intervention_interdict | loop_178_intervention_minimize)
(loop_178_context_branch | loop_178_then_branch | loop_178_operator_branch | loop_178_result_branch | loop_178_taxonomy_branch | loop_178_intervention_recognize | loop_178_intervention_interdict | loop_178_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_178_verdict)
