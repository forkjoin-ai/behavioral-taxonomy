(loop_178_verdict: BehaviorVerdict { loopId: 178, loopName: 'The%20Sweaty%20Lip%20Loop', then: 'it%20acts%20as%20a%20cartoonish%20%22Tell%22%20for%20deception%20(The%20Suspicion%20Operator)', result: 'the%20individual%20being%20unable%20to%20bluff%2C%20forcing%20a%20strategy%20of%20**Transparency**', operatorName: 'The%20Suspicion%20Operator', operatorMechanism: 'it%20acts%20as%20a%20cartoonish%20%22Tell%22%20for%20deception', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
