(loop_178_sink: BehaviorSink)
(loop_178_start: BehaviorStart { loopId: 178, loopName: 'The%20Sweaty%20Lip%20Loop', given: 'Hyperhidrosis%20specifically%20on%20the%20upper%20lip', when: 'lying%20or%20stressed', then: 'it%20acts%20as%20a%20cartoonish%20%22Tell%22%20for%20deception%20(The%20Suspicion%20Operator)', result: 'the%20individual%20being%20unable%20to%20bluff%2C%20forcing%20a%20strategy%20of%20**Transparency**', operatorName: 'The%20Suspicion%20Operator', operatorMechanism: 'it%20acts%20as%20a%20cartoonish%20%22Tell%22%20for%20deception', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Seek%20feedback%20from%20trusted%20allies%20about%20perception%20gaps' })
(loop_178_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
