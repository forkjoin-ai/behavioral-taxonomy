(loop_885_context)-[:FORK { strategy: "behavior-branches" }]->(loop_885_context_branch | loop_885_then_branch | loop_885_operator_branch | loop_885_result_branch | loop_885_taxonomy_branch | loop_885_intervention_recognize | loop_885_intervention_interdict | loop_885_intervention_minimize)
(loop_885_context_branch | loop_885_then_branch | loop_885_operator_branch | loop_885_result_branch | loop_885_taxonomy_branch | loop_885_intervention_recognize | loop_885_intervention_interdict | loop_885_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_885_verdict)
(loop_885_inactive)-[:PROCESS]->(loop_885_sink)
