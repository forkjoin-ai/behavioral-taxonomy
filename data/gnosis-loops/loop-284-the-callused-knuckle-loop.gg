(loop_284_context)-[:FORK { strategy: "behavior-branches" }]->(loop_284_context_branch | loop_284_then_branch | loop_284_operator_branch | loop_284_result_branch | loop_284_taxonomy_branch | loop_284_intervention_recognize | loop_284_intervention_interdict | loop_284_intervention_minimize)
(loop_284_context_branch | loop_284_then_branch | loop_284_operator_branch | loop_284_result_branch | loop_284_taxonomy_branch | loop_284_intervention_recognize | loop_284_intervention_interdict | loop_284_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_284_verdict)
(loop_284_inactive)-[:PROCESS]->(loop_284_sink)
(loop_284_verdict)-[:PROCESS]->(loop_284_sink)
(loop_284_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_284_then_branch)
