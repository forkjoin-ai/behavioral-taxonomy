(loop_4003_context)-[:FORK { strategy: "behavior-branches" }]->(loop_4003_context_branch | loop_4003_then_branch | loop_4003_operator_branch | loop_4003_result_branch | loop_4003_taxonomy_branch | loop_4003_intervention_recognize | loop_4003_intervention_interdict | loop_4003_intervention_minimize)
(loop_4003_context_branch | loop_4003_then_branch | loop_4003_operator_branch | loop_4003_result_branch | loop_4003_taxonomy_branch | loop_4003_intervention_recognize | loop_4003_intervention_interdict | loop_4003_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_4003_verdict)
