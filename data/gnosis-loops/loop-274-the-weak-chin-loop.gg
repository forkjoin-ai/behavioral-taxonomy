// Topology
(loop_274_start)-[:PROCESS]->(loop_274_given_gate)
(loop_274_given_gate)-[:PROCESS { case: "ok" }]->(loop_274_when_gate)
(loop_274_given_gate)-[:PROCESS { case: "err" }]->(loop_274_inactive)
(loop_274_when_gate)-[:PROCESS { case: "ok" }]->(loop_274_context)
(loop_274_when_gate)-[:PROCESS { case: "err" }]->(loop_274_inactive)
(loop_274_context)-[:FORK { strategy: "behavior-branches" }]->(loop_274_context_branch | loop_274_then_branch | loop_274_operator_branch | loop_274_result_branch | loop_274_taxonomy_branch | loop_274_intervention_recognize | loop_274_intervention_leverage)
(loop_274_context_branch | loop_274_then_branch | loop_274_operator_branch | loop_274_result_branch | loop_274_taxonomy_branch | loop_274_intervention_recognize | loop_274_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_274_verdict)
(loop_274_inactive)-[:PROCESS]->(loop_274_sink)
(loop_274_verdict)-[:PROCESS]->(loop_274_sink)
(loop_274_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_274_then_branch)
(loop_274_intervention_leverage)-[:INTERFERE { mode: "constructive" }]->(loop_274_result_branch)