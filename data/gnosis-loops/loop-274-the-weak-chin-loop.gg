(loop_274_inactive: BehaviorTerminal { loopId: 274, loopName: 'The%20Weak%20Chin%20Loop' })
(loop_274_intervention_leverage: BehaviorEmit { emission: 'intervention', interventionKind: 'leverage', text: 'Display%20in%20leadership%20or%20authority%20situations' })
