(loop_896_context)-[:FORK { strategy: "behavior-branches" }]->(loop_896_context_branch | loop_896_then_branch | loop_896_operator_branch | loop_896_result_branch | loop_896_taxonomy_branch | loop_896_intervention_recognize | loop_896_intervention_interdict | loop_896_intervention_minimize)
(loop_896_context_branch | loop_896_then_branch | loop_896_operator_branch | loop_896_result_branch | loop_896_taxonomy_branch | loop_896_intervention_recognize | loop_896_intervention_interdict | loop_896_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_896_verdict)
