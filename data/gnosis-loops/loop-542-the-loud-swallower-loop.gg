// Topology
(loop_542_start)-[:PROCESS]->(loop_542_given_gate)
(loop_542_given_gate)-[:PROCESS { case: "ok" }]->(loop_542_when_gate)
(loop_542_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_542_inactive)
(loop_542_when_gate)-[:PROCESS { case: "ok" }]->(loop_542_context)
(loop_542_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_542_inactive)
(loop_542_context)-[:FORK { strategy: "behavior-branches" }]->(loop_542_context_branch | loop_542_then_branch | loop_542_operator_branch | loop_542_result_branch | loop_542_taxonomy_branch | loop_542_intervention_recognize | loop_542_intervention_interdict | loop_542_intervention_minimize)
(loop_542_context_branch | loop_542_then_branch | loop_542_operator_branch | loop_542_result_branch | loop_542_taxonomy_branch | loop_542_intervention_recognize | loop_542_intervention_interdict | loop_542_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_542_verdict)
(loop_542_inactive)-[:PROCESS]->(loop_542_sink)
(loop_542_verdict)-[:PROCESS]->(loop_542_sink)
(loop_542_verdict)-[:MEASURE]->(loop_542_sink)
