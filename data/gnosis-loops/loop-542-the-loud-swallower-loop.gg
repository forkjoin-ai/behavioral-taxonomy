(loop_542_inactive: BehaviorTerminal { loopId: 542, loopName: 'The%20Loud%20Swallower%20Loop' })
(loop_542_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22' })
