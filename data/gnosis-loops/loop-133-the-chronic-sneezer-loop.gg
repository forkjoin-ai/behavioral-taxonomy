(loop_133_given_gate: BehaviorAssess { stage: 'given', text: 'High%20Histamine%20Response%20(Constant%20allergies)' })
(loop_133_inactive: BehaviorTerminal { loopId: 133, loopName: 'The%20Chronic%20Sneezer%20Loop' })
