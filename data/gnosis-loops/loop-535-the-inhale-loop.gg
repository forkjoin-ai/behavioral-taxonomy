(loop_535_context)-[:FORK { strategy: "behavior-branches" }]->(loop_535_context_branch | loop_535_then_branch | loop_535_operator_branch | loop_535_result_branch | loop_535_taxonomy_branch | loop_535_intervention_recognize | loop_535_intervention_interdict | loop_535_intervention_minimize)
(loop_535_context_branch | loop_535_then_branch | loop_535_operator_branch | loop_535_result_branch | loop_535_taxonomy_branch | loop_535_intervention_recognize | loop_535_intervention_interdict | loop_535_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_535_verdict)
(loop_535_inactive)-[:PROCESS]->(loop_535_sink)
(loop_535_verdict)-[:PROCESS]->(loop_535_sink)
(loop_535_verdict)-[:MEASURE]->(loop_535_sink)
