// Topology
(loop_535_start)-[:PROCESS]->(loop_535_given_gate)
(loop_535_given_gate)-[:PROCESS { case: "ok" }]->(loop_535_when_gate)
(loop_535_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_535_inactive)
