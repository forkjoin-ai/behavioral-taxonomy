(loop_422_inactive: BehaviorTerminal { loopId: 422, loopName: 'The%20Table%20Shaker%20Loop' })
(loop_422_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
