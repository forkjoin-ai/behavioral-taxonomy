(loop_422_context)-[:FORK { strategy: "behavior-branches" }]->(loop_422_context_branch | loop_422_then_branch | loop_422_operator_branch | loop_422_result_branch | loop_422_taxonomy_branch | loop_422_intervention_recognize | loop_422_intervention_interdict | loop_422_intervention_minimize)
(loop_422_context_branch | loop_422_then_branch | loop_422_operator_branch | loop_422_result_branch | loop_422_taxonomy_branch | loop_422_intervention_recognize | loop_422_intervention_interdict | loop_422_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_422_verdict)
(loop_422_inactive)-[:PROCESS]->(loop_422_sink)
(loop_422_verdict)-[:PROCESS]->(loop_422_sink)
(loop_422_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_422_then_branch)
