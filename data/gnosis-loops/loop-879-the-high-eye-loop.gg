(loop_879_start: BehaviorStart { loopId: 879, loopName: 'The%20High%20Eye%20Loop', given: 'Vertical%20misalignment%20(one%20eye%20higher)', when: 'resting', then: 'the%20face%20looks%20%22Twisted%22%20or%20%22Skeptical%22%20(The%20Doubt%20Operator)', result: "subconscious%20distrust%20of%20the%20individual's%20motives", operatorName: 'The%20Doubt%20Operator', operatorMechanism: 'the%20face%20looks%20%22Twisted%22%20or%20%22Skeptical%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'TRUST', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_leverage: 'Consistently%20display%20this%20signal%20in%20professional%20contexts' })
