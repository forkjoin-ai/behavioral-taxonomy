(loop_879_context)-[:FORK { strategy: "behavior-branches" }]->(loop_879_context_branch | loop_879_then_branch | loop_879_operator_branch | loop_879_result_branch | loop_879_taxonomy_branch | loop_879_intervention_recognize | loop_879_intervention_leverage)
