(loop_1044_sink: BehaviorSink)
(loop_1044_start: BehaviorStart { loopId: 1044, loopName: 'The%20Autopilot%20Loop', given: 'Over-familiarity%20with%20a%20route', when: 'driving%20to%20a%20new%20location%20on%20a%20familiar%20road', then: 'the%20driver%20accidentally%20drives%20to%20work%20(The%20Script%20Override)', result: 'arriving%20at%20the%20wrong%20destination%20with%20no%20memory%20of%20the%20drive', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20driver%20accidentally%20drives%20to%20work%20(The%20Script%20Override)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Seek%20feedback%20from%20trusted%20allies%20about%20perception%20gaps' })
(loop_1044_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1044_then_branch: BehaviorEmit { emission: 'then', text: 'the%20driver%20accidentally%20drives%20to%20work%20(The%20Script%20Override)' })
(loop_1044_verdict: BehaviorVerdict { loopId: 1044, loopName: 'The%20Autopilot%20Loop', then: 'the%20driver%20accidentally%20drives%20to%20work%20(The%20Script%20Override)', result: 'arriving%20at%20the%20wrong%20destination%20with%20no%20memory%20of%20the%20drive', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20driver%20accidentally%20drives%20to%20work%20(The%20Script%20Override)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1044_when_gate: BehaviorAssess { stage: 'when', text: 'driving%20to%20a%20new%20location%20on%20a%20familiar%20road' })

// Topology
(loop_1044_start)-[:PROCESS]->(loop_1044_given_gate)
(loop_1044_given_gate)-[:PROCESS { case: "ok" }]->(loop_1044_when_gate)
(loop_1044_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_1044_inactive)
(loop_1044_when_gate)-[:PROCESS { case: "ok" }]->(loop_1044_context)
(loop_1044_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_1044_inactive)
(loop_1044_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1044_context_branch | loop_1044_then_branch | loop_1044_operator_branch | loop_1044_result_branch | loop_1044_taxonomy_branch | loop_1044_intervention_recognize | loop_1044_intervention_interdict | loop_1044_intervention_minimize)
(loop_1044_context_branch | loop_1044_then_branch | loop_1044_operator_branch | loop_1044_result_branch | loop_1044_taxonomy_branch | loop_1044_intervention_recognize | loop_1044_intervention_interdict | loop_1044_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1044_verdict)
(loop_1044_inactive)-[:PROCESS]->(loop_1044_sink)
(loop_1044_verdict)-[:PROCESS]->(loop_1044_sink)
(loop_1044_verdict)-[:MEASURE]->(loop_1044_sink)
(loop_1044_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_1044_then_branch)
