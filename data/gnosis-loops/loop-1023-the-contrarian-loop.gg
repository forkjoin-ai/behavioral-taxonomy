(loop_1023_verdict: BehaviorVerdict { loopId: 1023, loopName: 'The%20Contrarian%20Loop', then: 'disagreeing%20just%20to%20prove%20a%20point%20(The%20Thorn%20Operator)', result: 'the%20group%20expelling%20the%20individual%20to%20get%20work%20done', operatorName: 'The%20Thorn%20Operator', operatorMechanism: 'disagreeing%20just%20to%20prove%20a%20point', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
