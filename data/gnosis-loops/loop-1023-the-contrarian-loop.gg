(loop_1023_context_branch | loop_1023_then_branch | loop_1023_operator_branch | loop_1023_result_branch | loop_1023_taxonomy_branch | loop_1023_intervention_recognize | loop_1023_intervention_interdict | loop_1023_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1023_verdict)
