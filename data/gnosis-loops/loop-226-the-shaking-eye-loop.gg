(loop_226_start: BehaviorStart { loopId: 226, loopName: 'The%20Shaking%20Eye%20Loop', given: 'Involuntary%20repetitive%20eye%20movement', when: 'attempting%20to%20hold%20a%20steady%20gaze', then: 'observers%20perceive%20%22Intoxication%2C%22%20%22Dizziness%2C%22%20or%20%22Drug%20Use%22%20(The%20Instability%20Operator)', result: 'frequent%2C%20unfair%20drug%20testing%20or%20police%20scrutiny%2C%20leading%20to%20**Institutional%20Paranoia**', operatorName: 'The%20Instability%20Operator', operatorMechanism: 'observers%20perceive%20%22Intoxication%2C%22%20%22Dizziness%2C%22%20or%20%22Drug%20Use%22', origin: 'BEHAVIORAL', modality: 'VISUAL_DYNAMIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20microexpressions%20and%20movement%20patterns', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Ground%20yourself%20with%20deep%20breathing%3B%20this%20is%20a%20perceptual%20distortion%2C%20not%20reality.' })
