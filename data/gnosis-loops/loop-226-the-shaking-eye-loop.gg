(loop_226_context)-[:FORK { strategy: "behavior-branches" }]->(loop_226_context_branch | loop_226_then_branch | loop_226_operator_branch | loop_226_result_branch | loop_226_taxonomy_branch | loop_226_intervention_recognize | loop_226_intervention_interdict | loop_226_intervention_minimize)
(loop_226_context_branch | loop_226_then_branch | loop_226_operator_branch | loop_226_result_branch | loop_226_taxonomy_branch | loop_226_intervention_recognize | loop_226_intervention_interdict | loop_226_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_226_verdict)
