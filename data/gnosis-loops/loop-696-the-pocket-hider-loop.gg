(loop_696_start: BehaviorStart { loopId: 696, loopName: 'The%20Pocket%20Hider%20Loop', given: 'Hands%20buried%20deep%20in%20pockets', when: 'talking', then: 'it%20signals%20%22Casualness%22%20or%20%22Hiding%20Something%22%20(The%20Slouch%20Operator)', result: 'appearing%20unprofessional%20in%20formal%20settings', operatorName: 'The%20Slouch%20Operator', operatorMechanism: 'it%20signals%20%22Casualness%22%20or%20%22Hiding%20Something%22', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '8', intervention_recognize: 'Be%20aware%20of%20physical%20comfort%2Fdiscomfort%20in%20interactions', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
