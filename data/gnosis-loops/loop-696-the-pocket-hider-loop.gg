(loop_696_context_branch | loop_696_then_branch | loop_696_operator_branch | loop_696_result_branch | loop_696_taxonomy_branch | loop_696_intervention_recognize | loop_696_intervention_interdict | loop_696_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_696_verdict)
