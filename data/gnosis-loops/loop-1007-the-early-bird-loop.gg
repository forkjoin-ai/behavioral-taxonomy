(loop_1007_when_gate)-[:PROCESS { case: "ok" }]->(loop_1007_context)
(loop_1007_when_gate)-[:PROCESS { case: "err" }]->(loop_1007_inactive)
(loop_1007_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1007_context_branch | loop_1007_then_branch | loop_1007_operator_branch | loop_1007_result_branch | loop_1007_taxonomy_branch | loop_1007_intervention_recognize | loop_1007_intervention_interdict | loop_1007_intervention_minimize)
(loop_1007_context_branch | loop_1007_then_branch | loop_1007_operator_branch | loop_1007_result_branch | loop_1007_taxonomy_branch | loop_1007_intervention_recognize | loop_1007_intervention_interdict | loop_1007_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1007_verdict)
(loop_1007_inactive)-[:PROCESS]->(loop_1007_sink)
(loop_1007_verdict)-[:PROCESS]->(loop_1007_sink)
(loop_1007_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_1007_then_branch)
