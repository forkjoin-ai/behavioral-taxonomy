(loop_1007_inactive: BehaviorTerminal { loopId: 1007, loopName: 'The%20Early%20Bird%20Loop' })
(loop_1007_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
