// Topology
(loop_734_start)-[:PROCESS]->(loop_734_given_gate)
(loop_734_given_gate)-[:PROCESS { case: "ok" }]->(loop_734_when_gate)
(loop_734_given_gate)-[:PROCESS { case: "err" }]->(loop_734_inactive)
(loop_734_when_gate)-[:PROCESS { case: "ok" }]->(loop_734_context)
