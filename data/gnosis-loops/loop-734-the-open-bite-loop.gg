(loop_734_sink: BehaviorSink)
(loop_734_start: BehaviorStart { loopId: 734, loopName: 'The%20Open%20Bite%20Loop', given: "Front%20teeth%20don't%20touch%20when%20biting%20down", when: 'eating', then: 'the%20tongue%20is%20visible%20(The%20Lizard%20Operator)', result: '%22Messy%20Eater%22%20stereotype', operatorName: 'The%20Lizard%20Operator', operatorMechanism: 'the%20tongue%20is%20visible', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Be%20aware%20of%20physical%20comfort%2Fdiscomfort%20in%20interactions', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
(loop_734_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'SUBMISSION' })
(loop_734_then_branch: BehaviorEmit { emission: 'then', text: 'the%20tongue%20is%20visible%20(The%20Lizard%20Operator)' })
(loop_734_verdict: BehaviorVerdict { loopId: 734, loopName: 'The%20Open%20Bite%20Loop', then: 'the%20tongue%20is%20visible%20(The%20Lizard%20Operator)', result: '%22Messy%20Eater%22%20stereotype', operatorName: 'The%20Lizard%20Operator', operatorMechanism: 'the%20tongue%20is%20visible', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'SUBMISSION' })
