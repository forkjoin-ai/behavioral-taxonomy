(loop_518_context)-[:FORK { strategy: "behavior-branches" }]->(loop_518_context_branch | loop_518_then_branch | loop_518_operator_branch | loop_518_result_branch | loop_518_taxonomy_branch | loop_518_intervention_recognize | loop_518_intervention_leverage)
(loop_518_context_branch | loop_518_then_branch | loop_518_operator_branch | loop_518_result_branch | loop_518_taxonomy_branch | loop_518_intervention_recognize | loop_518_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_518_verdict)
(loop_518_inactive)-[:PROCESS]->(loop_518_sink)
