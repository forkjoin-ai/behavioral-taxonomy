(loop_518_start: BehaviorStart { loopId: 518, loopName: 'The%20Topper%20Loop', given: 'Placing%20the%20left%20hand%20*over*%20the%20handshake%20(sandwiching)', when: 'meeting%20a%20peer', then: 'it%20signals%20%22Condescension%22%20or%20%22Political%20Fakeness%22%20(The%20Senator%20Operator)', result: 'distrust%3B%20the%20recipient%20feels%20%22handled%22%20rather%20than%20greeted', operatorName: 'The%20Senator%20Operator', operatorMechanism: 'it%20signals%20%22Condescension%22%20or%20%22Political%20Fakeness%22', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'TRUST', interventionDifficulty: '6', intervention_recognize: 'Notice%20touch%20aversion%20or%20seeking%20behaviors', intervention_leverage: 'Use%20in%20high-stakes%20negotiations%20and%20first%20impressions' })
(loop_518_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'TRUST' })
(loop_518_then_branch: BehaviorEmit { emission: 'then', text: 'it%20signals%20%22Condescension%22%20or%20%22Political%20Fakeness%22%20(The%20Senator%20Operator)' })
(loop_518_verdict: BehaviorVerdict { loopId: 518, loopName: 'The%20Topper%20Loop', then: 'it%20signals%20%22Condescension%22%20or%20%22Political%20Fakeness%22%20(The%20Senator%20Operator)', result: 'distrust%3B%20the%20recipient%20feels%20%22handled%22%20rather%20than%20greeted', operatorName: 'The%20Senator%20Operator', operatorMechanism: 'it%20signals%20%22Condescension%22%20or%20%22Political%20Fakeness%22', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'TRUST' })
