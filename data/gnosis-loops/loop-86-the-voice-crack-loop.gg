(loop_86_start: BehaviorStart { loopId: 86, loopName: 'The%20Voice%20Crack%20Loop', given: 'Unstable%20Larynx%20(during%20puberty%20or%20stress)', when: 'attempting%20to%20assert%20authority', then: 'the%20voice%20breaks%2C%20triggering%20laughter%20(The%20Humor%20Operator%20-%20at%20expense)', result: '**Public%20Speaking%20Phobia**%20or%20**Voluntary%20Muteness**', operatorName: 'The%20Humor%20Operator', operatorMechanism: 'the%20voice%20breaks%2C%20triggering%20laughter', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_86_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_86_then_branch: BehaviorEmit { emission: 'then', text: 'the%20voice%20breaks%2C%20triggering%20laughter%20(The%20Humor%20Operator%20-%20at%20expense)' })
(loop_86_verdict: BehaviorVerdict { loopId: 86, loopName: 'The%20Voice%20Crack%20Loop', then: 'the%20voice%20breaks%2C%20triggering%20laughter%20(The%20Humor%20Operator%20-%20at%20expense)', result: '**Public%20Speaking%20Phobia**%20or%20**Voluntary%20Muteness**', operatorName: 'The%20Humor%20Operator', operatorMechanism: 'the%20voice%20breaks%2C%20triggering%20laughter', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_86_when_gate: BehaviorAssess { stage: 'when', text: 'attempting%20to%20assert%20authority' })

// Topology
(loop_86_start)-[:PROCESS]->(loop_86_given_gate)
(loop_86_given_gate)-[:PROCESS { case: "ok" }]->(loop_86_when_gate)
(loop_86_given_gate)-[:PROCESS { case: "err" }]->(loop_86_inactive)
(loop_86_when_gate)-[:PROCESS { case: "ok" }]->(loop_86_context)
(loop_86_when_gate)-[:PROCESS { case: "err" }]->(loop_86_inactive)
(loop_86_context)-[:FORK { strategy: "behavior-branches" }]->(loop_86_context_branch | loop_86_then_branch | loop_86_operator_branch | loop_86_result_branch | loop_86_taxonomy_branch | loop_86_intervention_recognize | loop_86_intervention_interdict | loop_86_intervention_minimize)
(loop_86_context_branch | loop_86_then_branch | loop_86_operator_branch | loop_86_result_branch | loop_86_taxonomy_branch | loop_86_intervention_recognize | loop_86_intervention_interdict | loop_86_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_86_verdict)
(loop_86_inactive)-[:PROCESS]->(loop_86_sink)
(loop_86_verdict)-[:PROCESS]->(loop_86_sink)
(loop_86_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_86_then_branch)
(loop_86_intervention_interdict)-[:INTERFERE { mode: "destructive" }]->(loop_86_then_branch)
(loop_86_intervention_minimize)-[:INTERFERE { mode: "destructive" }]->(loop_86_then_branch)