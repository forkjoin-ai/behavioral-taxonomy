(loop_211_context_branch | loop_211_then_branch | loop_211_operator_branch | loop_211_result_branch | loop_211_taxonomy_branch | loop_211_intervention_recognize | loop_211_intervention_interdict | loop_211_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_211_verdict)
(loop_211_inactive)-[:PROCESS]->(loop_211_sink)
