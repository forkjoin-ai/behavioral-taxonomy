(loop_594_then_branch: BehaviorEmit { emission: 'then', text: 'nothing%20moves%20(The%20Mannequin%20Operator)' })
(loop_594_verdict: BehaviorVerdict { loopId: 594, loopName: 'The%20Plastic%20Loop', then: 'nothing%20moves%20(The%20Mannequin%20Operator)', result: '%22Uncanny%20Valley%22%20discomfort%20in%20observers', operatorName: 'The%20Mannequin%20Operator', operatorMechanism: 'nothing%20moves', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
