(loop_594_start: BehaviorStart { loopId: 594, loopName: 'The%20Plastic%20Loop', given: 'Shiny%2C%20immobile%20skin', when: 'attempting%20to%20frown', then: 'nothing%20moves%20(The%20Mannequin%20Operator)', result: '%22Uncanny%20Valley%22%20discomfort%20in%20observers', operatorName: 'The%20Mannequin%20Operator', operatorMechanism: 'nothing%20moves', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '5', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
