// behavioral-loop-357.gg
// Executable Gnosis projection for The Turtle Shell Loop.

// Nodes
(loop_357_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_357_context_branch: BehaviorEmit { emission: 'context' })
(loop_357_given_gate: BehaviorAssess { stage: 'given', text: 'Overdeveloped%20Trapezius%20muscles%20%2B%20short%20neck' })
(loop_357_inactive: BehaviorTerminal { loopId: 357, loopName: 'The%20Turtle%20Shell%20Loop' })
