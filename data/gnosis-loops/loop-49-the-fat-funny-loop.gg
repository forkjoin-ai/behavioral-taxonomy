// behavioral-loop-49.gg
// Executable Gnosis projection for The Fat-Funny Loop.

// Nodes
(loop_49_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_49_context_branch: BehaviorEmit { emission: 'context' })
(loop_49_given_gate: BehaviorAssess { stage: 'given', text: 'Endomorphy%20%2B%20High%20Verbal%20Intelligence' })
(loop_49_inactive: BehaviorTerminal { loopId: 49, loopName: 'The%20Fat-Funny%20Loop' })
(loop_49_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
