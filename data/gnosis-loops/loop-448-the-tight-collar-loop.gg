// Topology
(loop_448_start)-[:PROCESS]->(loop_448_given_gate)
(loop_448_given_gate)-[:PROCESS { case: "ok" }]->(loop_448_when_gate)
(loop_448_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_448_inactive)
(loop_448_when_gate)-[:PROCESS { case: "ok" }]->(loop_448_context)
(loop_448_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_448_inactive)
(loop_448_context)-[:FORK { strategy: "behavior-branches" }]->(loop_448_context_branch | loop_448_then_branch | loop_448_operator_branch | loop_448_result_branch | loop_448_taxonomy_branch | loop_448_intervention_recognize | loop_448_intervention_interdict | loop_448_intervention_minimize)
(loop_448_context_branch | loop_448_then_branch | loop_448_operator_branch | loop_448_result_branch | loop_448_taxonomy_branch | loop_448_intervention_recognize | loop_448_intervention_interdict | loop_448_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_448_verdict)
(loop_448_inactive)-[:PROCESS]->(loop_448_sink)
(loop_448_verdict)-[:PROCESS]->(loop_448_sink)
(loop_448_verdict)-[:MEASURE]->(loop_448_sink)
(loop_448_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_448_then_branch)
(loop_448_intervention_interdict)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_448_then_branch)
