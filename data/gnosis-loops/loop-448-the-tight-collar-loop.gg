(loop_448_then_branch: BehaviorEmit { emission: 'then', text: 'the%20face%20bulges%20and%20reddens%20(The%20Strangled%20Operator)' })
(loop_448_verdict: BehaviorVerdict { loopId: 448, loopName: 'The%20Tight%20Collar%20Loop', then: 'the%20face%20bulges%20and%20reddens%20(The%20Strangled%20Operator)', result: 'the%20individual%20looking%20like%20they%20are%20about%20to%20explode', operatorName: 'The%20Strangled%20Operator', operatorMechanism: 'the%20face%20bulges%20and%20reddens', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
