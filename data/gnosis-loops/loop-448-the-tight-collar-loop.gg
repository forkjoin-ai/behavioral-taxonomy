(loop_448_start: BehaviorStart { loopId: 448, loopName: 'The%20Tight%20Collar%20Loop', given: 'Shirt%20collar%20digging%20into%20neck%20fat', when: 'speaking', then: 'the%20face%20bulges%20and%20reddens%20(The%20Strangled%20Operator)', result: 'the%20individual%20looking%20like%20they%20are%20about%20to%20explode', operatorName: 'The%20Strangled%20Operator', operatorMechanism: 'the%20face%20bulges%20and%20reddens', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
