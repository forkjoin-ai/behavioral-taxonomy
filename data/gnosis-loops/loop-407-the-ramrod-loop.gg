(loop_407_context)-[:FORK { strategy: "behavior-branches" }]->(loop_407_context_branch | loop_407_then_branch | loop_407_operator_branch | loop_407_result_branch | loop_407_taxonomy_branch | loop_407_intervention_recognize | loop_407_intervention_interdict | loop_407_intervention_minimize)
(loop_407_context_branch | loop_407_then_branch | loop_407_operator_branch | loop_407_result_branch | loop_407_taxonomy_branch | loop_407_intervention_recognize | loop_407_intervention_interdict | loop_407_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_407_verdict)
(loop_407_inactive)-[:PROCESS]->(loop_407_sink)
