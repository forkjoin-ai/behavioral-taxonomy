(loop_407_inactive: BehaviorTerminal { loopId: 407, loopName: 'The%20Ramrod%20Loop' })
(loop_407_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
