(loop_329_given_gate: BehaviorAssess { stage: 'given', text: 'Head%20turned%20away%20%2B%20eyes%20looking%20back' })
(loop_329_inactive: BehaviorTerminal { loopId: 329, loopName: 'The%20Side-Eye%20Loop' })
