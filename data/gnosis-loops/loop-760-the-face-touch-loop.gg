(loop_760_given_gate: BehaviorAssess { stage: 'given', text: 'Covering%20mouth%2Fnose%20while%20speaking' })
(loop_760_inactive: BehaviorTerminal { loopId: 760, loopName: 'The%20Face-Touch%20Loop' })
(loop_760_intervention_leverage: BehaviorEmit { emission: 'intervention', interventionKind: 'leverage', text: 'Pair%20with%20competence%20demonstrations%20for%20maximum%20effect' })
