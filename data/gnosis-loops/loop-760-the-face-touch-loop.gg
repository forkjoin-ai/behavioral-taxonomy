// Topology
(loop_760_start)-[:PROCESS]->(loop_760_given_gate)
(loop_760_given_gate)-[:PROCESS { case: "ok" }]->(loop_760_when_gate)
(loop_760_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_760_inactive)
(loop_760_when_gate)-[:PROCESS { case: "ok" }]->(loop_760_context)
(loop_760_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_760_inactive)
(loop_760_context)-[:FORK { strategy: "behavior-branches" }]->(loop_760_context_branch | loop_760_then_branch | loop_760_operator_branch | loop_760_result_branch | loop_760_taxonomy_branch | loop_760_intervention_recognize | loop_760_intervention_leverage)
(loop_760_context_branch | loop_760_then_branch | loop_760_operator_branch | loop_760_result_branch | loop_760_taxonomy_branch | loop_760_intervention_recognize | loop_760_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_760_verdict)
(loop_760_inactive)-[:PROCESS]->(loop_760_sink)
(loop_760_verdict)-[:PROCESS]->(loop_760_sink)
(loop_760_verdict)-[:MEASURE]->(loop_760_sink)
(loop_760_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_760_then_branch)
(loop_760_intervention_leverage)-[:PROCESS { mode: "constructive", role: "intervention-sliver" }]->(loop_760_result_branch)