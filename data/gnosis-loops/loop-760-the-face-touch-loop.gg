(loop_760_result_branch: BehaviorEmit { emission: 'result', text: 'low%20credibility' })
(loop_760_sink: BehaviorSink)
(loop_760_start: BehaviorStart { loopId: 760, loopName: 'The%20Face-Touch%20Loop', given: 'Covering%20mouth%2Fnose%20while%20speaking', when: 'telling%20a%20story', then: 'it%20signals%20%22Lying%22%20or%20%22Uncertainty%22%20(The%20Muffle%20Operator)', result: 'low%20credibility', operatorName: 'The%20Muffle%20Operator', operatorMechanism: 'it%20signals%20%22Lying%22%20or%20%22Uncertainty%22', origin: 'BEHAVIORAL', modality: 'AUDITORY', mutability: '1', valences: 'TRUST', interventionDifficulty: '5', intervention_recognize: 'Listen%20for%20voice%20changes%20(pitch%2C%20pace%2C%20volume)', intervention_leverage: 'Pair%20with%20competence%20demonstrations%20for%20maximum%20effect' })
(loop_760_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'AUDITORY', mutability: '1', valences: 'TRUST' })
(loop_760_then_branch: BehaviorEmit { emission: 'then', text: 'it%20signals%20%22Lying%22%20or%20%22Uncertainty%22%20(The%20Muffle%20Operator)' })
(loop_760_verdict: BehaviorVerdict { loopId: 760, loopName: 'The%20Face-Touch%20Loop', then: 'it%20signals%20%22Lying%22%20or%20%22Uncertainty%22%20(The%20Muffle%20Operator)', result: 'low%20credibility', operatorName: 'The%20Muffle%20Operator', operatorMechanism: 'it%20signals%20%22Lying%22%20or%20%22Uncertainty%22', origin: 'BEHAVIORAL', modality: 'AUDITORY', mutability: '1', valences: 'TRUST' })
