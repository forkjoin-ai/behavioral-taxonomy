(loop_227_when_gate)-[:PROCESS { case: "err" }]->(loop_227_inactive)
(loop_227_context)-[:FORK { strategy: "behavior-branches" }]->(loop_227_context_branch | loop_227_then_branch | loop_227_operator_branch | loop_227_result_branch | loop_227_taxonomy_branch | loop_227_intervention_recognize | loop_227_intervention_interdict | loop_227_intervention_minimize)
(loop_227_context_branch | loop_227_then_branch | loop_227_operator_branch | loop_227_result_branch | loop_227_taxonomy_branch | loop_227_intervention_recognize | loop_227_intervention_interdict | loop_227_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_227_verdict)
(loop_227_inactive)-[:PROCESS]->(loop_227_sink)
