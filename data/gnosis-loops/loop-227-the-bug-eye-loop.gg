// behavioral-loop-227.gg
// Executable Gnosis projection for The Bug Eye Loop.

// Nodes
(loop_227_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_227_context_branch: BehaviorEmit { emission: 'context' })
(loop_227_given_gate: BehaviorAssess { stage: 'given', text: "Proptosis%20(Bulging%20eyes%2C%20e.g.%2C%20Graves'%20disease)" })
(loop_227_inactive: BehaviorTerminal { loopId: 227, loopName: 'The%20Bug%20Eye%20Loop' })
(loop_227_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20community%20with%20others%20managing%20similar%20conditions' })
