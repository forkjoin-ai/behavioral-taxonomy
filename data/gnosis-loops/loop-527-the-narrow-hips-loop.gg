(loop_527_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Watch%20for%20snap%20judgments%20based%20on%20appearance' })
(loop_527_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Androgynous%20Operator', mechanism: 'the%20silhouette%20is%20%22Tubular%22%20or%20%22Boyish%22' })
