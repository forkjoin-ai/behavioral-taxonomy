(loop_730_context)-[:FORK { strategy: "behavior-branches" }]->(loop_730_context_branch | loop_730_then_branch | loop_730_operator_branch | loop_730_result_branch | loop_730_taxonomy_branch | loop_730_intervention_recognize | loop_730_intervention_interdict | loop_730_intervention_minimize)
