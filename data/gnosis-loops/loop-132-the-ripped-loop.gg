// behavioral-loop-132.gg
// Executable Gnosis projection for The Ripped Loop.

// Nodes
(loop_132_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_132_context_branch: BehaviorEmit { emission: 'context' })
(loop_132_given_gate: BehaviorAssess { stage: 'given', text: 'Visible%20striations%20and%20extreme%20vascularity' })
(loop_132_inactive: BehaviorTerminal { loopId: 132, loopName: 'The%20Ripped%20Loop' })
(loop_132_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
