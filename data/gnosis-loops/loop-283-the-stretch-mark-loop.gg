(loop_283_start: BehaviorStart { loopId: 283, loopName: 'The%20Stretch%20Mark%20Loop', given: 'Visible%20lines%20on%20arms%2Flegs%20(growth%20spurts%20or%20weight)', when: 'wearing%20swimwear', then: 'observers%20assume%20%22Weight%20History%22%20(The%20Gluttony%20Operator)', result: 'the%20individual%20avoiding%20swimming%2C%20missing%20out%20on%20**Social%20Bonding**', operatorName: 'The%20Gluttony%20Operator', operatorMechanism: 'observers%20assume%20%22Weight%20History%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'REPULSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Seek%20feedback%20from%20trusted%20allies%20about%20perception%20gaps' })
