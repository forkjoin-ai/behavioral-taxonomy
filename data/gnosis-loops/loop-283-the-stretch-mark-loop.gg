(loop_283_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_283_inactive)
(loop_283_context)-[:FORK { strategy: "behavior-branches" }]->(loop_283_context_branch | loop_283_then_branch | loop_283_operator_branch | loop_283_result_branch | loop_283_taxonomy_branch | loop_283_intervention_recognize | loop_283_intervention_interdict | loop_283_intervention_minimize)
(loop_283_context_branch | loop_283_then_branch | loop_283_operator_branch | loop_283_result_branch | loop_283_taxonomy_branch | loop_283_intervention_recognize | loop_283_intervention_interdict | loop_283_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_283_verdict)
(loop_283_inactive)-[:PROCESS]->(loop_283_sink)
