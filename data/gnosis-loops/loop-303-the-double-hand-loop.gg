// Topology
(loop_303_start)-[:PROCESS]->(loop_303_given_gate)
(loop_303_given_gate)-[:PROCESS { case: "ok" }]->(loop_303_when_gate)
(loop_303_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_303_inactive)
(loop_303_when_gate)-[:PROCESS { case: "ok" }]->(loop_303_context)
(loop_303_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_303_inactive)
(loop_303_context)-[:FORK { strategy: "behavior-branches" }]->(loop_303_context_branch | loop_303_then_branch | loop_303_operator_branch | loop_303_result_branch | loop_303_taxonomy_branch | loop_303_intervention_recognize | loop_303_intervention_leverage)
(loop_303_context_branch | loop_303_then_branch | loop_303_operator_branch | loop_303_result_branch | loop_303_taxonomy_branch | loop_303_intervention_recognize | loop_303_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_303_verdict)
(loop_303_inactive)-[:PROCESS]->(loop_303_sink)
(loop_303_verdict)-[:PROCESS]->(loop_303_sink)
(loop_303_verdict)-[:MEASURE]->(loop_303_sink)
(loop_303_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_303_then_branch)
(loop_303_intervention_leverage)-[:PROCESS { mode: "constructive", role: "intervention-sliver" }]->(loop_303_result_branch)