(loop_303_start: BehaviorStart { loopId: 303, loopName: 'The%20Double%20Hand%20Loop', given: 'Habit%20of%20using%20two%20hands%20to%20shake', when: 'meeting%20a%20peer', then: 'the%20gesture%20feels%20%22Over-familiar%22%20or%20%22Fake%22%20(The%20Manipulation%20Operator)', result: 'the%20recipient%20checking%20for%20their%20wallet%20(distrust)', operatorName: 'The%20Manipulation%20Operator', operatorMechanism: 'the%20gesture%20feels%20%22Over-familiar%22%20or%20%22Fake%22', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'TRUST', interventionDifficulty: '6', intervention_recognize: 'Notice%20touch%20aversion%20or%20seeking%20behaviors', intervention_leverage: 'Use%20in%20high-stakes%20negotiations%20and%20first%20impressions' })
(loop_303_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'TRUST' })
(loop_303_then_branch: BehaviorEmit { emission: 'then', text: 'the%20gesture%20feels%20%22Over-familiar%22%20or%20%22Fake%22%20(The%20Manipulation%20Operator)' })
(loop_303_verdict: BehaviorVerdict { loopId: 303, loopName: 'The%20Double%20Hand%20Loop', then: 'the%20gesture%20feels%20%22Over-familiar%22%20or%20%22Fake%22%20(The%20Manipulation%20Operator)', result: 'the%20recipient%20checking%20for%20their%20wallet%20(distrust)', operatorName: 'The%20Manipulation%20Operator', operatorMechanism: 'the%20gesture%20feels%20%22Over-familiar%22%20or%20%22Fake%22', origin: 'BEHAVIORAL', modality: 'HAPTIC', mutability: '1', valences: 'TRUST' })
