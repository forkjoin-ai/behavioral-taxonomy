(loop_474_inactive: BehaviorTerminal { loopId: 474, loopName: 'The%20Unibrow%20Loop' })
(loop_474_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
