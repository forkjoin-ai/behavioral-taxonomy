(loop_930_context)-[:FORK { strategy: "behavior-branches" }]->(loop_930_context_branch | loop_930_then_branch | loop_930_operator_branch | loop_930_result_branch | loop_930_taxonomy_branch | loop_930_intervention_recognize | loop_930_intervention_interdict | loop_930_intervention_minimize)
(loop_930_context_branch | loop_930_then_branch | loop_930_operator_branch | loop_930_result_branch | loop_930_taxonomy_branch | loop_930_intervention_recognize | loop_930_intervention_interdict | loop_930_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_930_verdict)
(loop_930_inactive)-[:PROCESS]->(loop_930_sink)
