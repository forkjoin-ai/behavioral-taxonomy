(loop_930_start: BehaviorStart { loopId: 930, loopName: 'The%20Old%20Book%20Loop', given: 'Lipid%20oxidation%20on%20the%20skin%20surface%20(Age%2040%2B)', when: 'in%20a%20confined%20space', then: 'the%20scent%20is%20%22Musty%22%20or%20%22Grassy%22%20(The%20Senescence%20Operator)', result: 'instant%20age%20categorization%2C%20regardless%20of%20how%20young%20the%20face%20looks', operatorName: 'The%20Senescence%20Operator', operatorMechanism: 'the%20scent%20is%20%22Musty%22%20or%20%22Grassy%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_930_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_930_then_branch: BehaviorEmit { emission: 'then', text: 'the%20scent%20is%20%22Musty%22%20or%20%22Grassy%22%20(The%20Senescence%20Operator)' })
(loop_930_verdict: BehaviorVerdict { loopId: 930, loopName: 'The%20Old%20Book%20Loop', then: 'the%20scent%20is%20%22Musty%22%20or%20%22Grassy%22%20(The%20Senescence%20Operator)', result: 'instant%20age%20categorization%2C%20regardless%20of%20how%20young%20the%20face%20looks', operatorName: 'The%20Senescence%20Operator', operatorMechanism: 'the%20scent%20is%20%22Musty%22%20or%20%22Grassy%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_930_when_gate: BehaviorAssess { stage: 'when', text: 'in%20a%20confined%20space' })

// Topology
(loop_930_start)-[:PROCESS]->(loop_930_given_gate)
