(loop_804_context)-[:FORK { strategy: "behavior-branches" }]->(loop_804_context_branch | loop_804_then_branch | loop_804_operator_branch | loop_804_result_branch | loop_804_taxonomy_branch | loop_804_intervention_recognize | loop_804_intervention_interdict | loop_804_intervention_minimize)
(loop_804_context_branch | loop_804_then_branch | loop_804_operator_branch | loop_804_result_branch | loop_804_taxonomy_branch | loop_804_intervention_recognize | loop_804_intervention_interdict | loop_804_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_804_verdict)
