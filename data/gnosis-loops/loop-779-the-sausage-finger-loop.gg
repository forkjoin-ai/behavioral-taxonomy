(loop_779_start: BehaviorStart { loopId: 779, loopName: 'The%20Sausage%20Finger%20Loop', given: 'Swollen%2C%20uniform%20digits%20(no%20taper)', when: 'performing%20fine%20motor%20tasks', then: 'observers%20assume%20%22Clumsiness%22%20(The%20Fumble%20Operator)', result: 'surprise%20when%20the%20individual%20displays%20dexterity%20(e.g.%2C%20playing%20piano)', operatorName: 'The%20Fumble%20Operator', operatorMechanism: 'observers%20assume%20%22Clumsiness%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
