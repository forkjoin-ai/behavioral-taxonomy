// behavioral-loop-106.gg
// Executable Gnosis projection for The Ear Flap Loop.

// Nodes
(loop_106_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_106_context_branch: BehaviorEmit { emission: 'context' })
(loop_106_given_gate: BehaviorAssess { stage: 'given', text: 'Protruding%20Auricles' })
(loop_106_inactive: BehaviorTerminal { loopId: 106, loopName: 'The%20Ear%20Flap%20Loop' })
(loop_106_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
