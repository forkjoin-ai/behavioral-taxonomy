(loop_614_context_branch | loop_614_then_branch | loop_614_operator_branch | loop_614_result_branch | loop_614_taxonomy_branch | loop_614_intervention_recognize | loop_614_intervention_interdict | loop_614_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_614_verdict)
(loop_614_inactive)-[:PROCESS]->(loop_614_sink)
