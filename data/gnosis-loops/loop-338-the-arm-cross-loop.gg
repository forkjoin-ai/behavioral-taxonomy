(loop_338_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_338_inactive)
(loop_338_context)-[:FORK { strategy: "behavior-branches" }]->(loop_338_context_branch | loop_338_then_branch | loop_338_operator_branch | loop_338_result_branch | loop_338_taxonomy_branch | loop_338_intervention_recognize | loop_338_intervention_interdict | loop_338_intervention_minimize)
(loop_338_context_branch | loop_338_then_branch | loop_338_operator_branch | loop_338_result_branch | loop_338_taxonomy_branch | loop_338_intervention_recognize | loop_338_intervention_interdict | loop_338_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_338_verdict)
