// Topology
(loop_338_start)-[:PROCESS]->(loop_338_given_gate)
(loop_338_given_gate)-[:PROCESS { case: "ok" }]->(loop_338_when_gate)
(loop_338_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_338_inactive)
