(loop_9005_sink: BehaviorSink)
(loop_9005_start: BehaviorStart { loopId: 9005, loopName: 'The%20Bullwhip%20Effect%20Loop', given: 'A%20multi-stage%20supply%20chain%20(Retail%20-%3E%20Distributor%20-%3E%20Factory)', when: 'A%20small%20fluctuation%20in%20consumer%20demand%20occurs%20(%2B5%25)', then: 'Each%20upstream%20node%20over-orders%20to%20create%20a%20safety%20buffer', result: 'Massive%20volatility%20at%20the%20source%20(Factory%20builds%20%2B50%25)%20based%20on%20minor%20noise%20at%20the%20endpoint', operatorName: 'Unknown%20Operator', operatorMechanism: 'Unknown%20mechanism', origin: 'BEHAVIORAL', modality: 'META', mutability: 'FLUID', valences: 'SUBMISSION', interventionDifficulty: '5', intervention_recognize: 'Pay%20attention%20to%20body%20language%20shifts', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_9005_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'META', mutability: 'FLUID', valences: 'SUBMISSION' })
(loop_9005_then_branch: BehaviorEmit { emission: 'then', text: 'Each%20upstream%20node%20over-orders%20to%20create%20a%20safety%20buffer' })
(loop_9005_verdict: BehaviorVerdict { loopId: 9005, loopName: 'The%20Bullwhip%20Effect%20Loop', then: 'Each%20upstream%20node%20over-orders%20to%20create%20a%20safety%20buffer', result: 'Massive%20volatility%20at%20the%20source%20(Factory%20builds%20%2B50%25)%20based%20on%20minor%20noise%20at%20the%20endpoint', operatorName: 'Unknown%20Operator', operatorMechanism: 'Unknown%20mechanism', origin: 'BEHAVIORAL', modality: 'META', mutability: 'FLUID', valences: 'SUBMISSION' })
(loop_9005_when_gate: BehaviorAssess { stage: 'when', text: 'A%20small%20fluctuation%20in%20consumer%20demand%20occurs%20(%2B5%25)' })

// Topology
(loop_9005_start)-[:PROCESS]->(loop_9005_given_gate)
(loop_9005_given_gate)-[:PROCESS { case: "ok" }]->(loop_9005_when_gate)
(loop_9005_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_9005_inactive)
(loop_9005_when_gate)-[:PROCESS { case: "ok" }]->(loop_9005_context)
(loop_9005_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_9005_inactive)
(loop_9005_context)-[:FORK { strategy: "behavior-branches" }]->(loop_9005_context_branch | loop_9005_then_branch | loop_9005_operator_branch | loop_9005_result_branch | loop_9005_taxonomy_branch | loop_9005_intervention_recognize | loop_9005_intervention_interdict | loop_9005_intervention_minimize)
(loop_9005_context_branch | loop_9005_then_branch | loop_9005_operator_branch | loop_9005_result_branch | loop_9005_taxonomy_branch | loop_9005_intervention_recognize | loop_9005_intervention_interdict | loop_9005_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_9005_verdict)
(loop_9005_inactive)-[:PROCESS]->(loop_9005_sink)
(loop_9005_verdict)-[:PROCESS]->(loop_9005_sink)
(loop_9005_verdict)-[:MEASURE]->(loop_9005_sink)
(loop_9005_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_9005_then_branch)
