(loop_312_inactive: BehaviorTerminal { loopId: 312, loopName: 'The%20Radio%20Voice%20Loop' })
(loop_312_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
