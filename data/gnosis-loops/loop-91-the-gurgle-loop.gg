(loop_91_context_branch | loop_91_then_branch | loop_91_operator_branch | loop_91_result_branch | loop_91_taxonomy_branch | loop_91_intervention_recognize | loop_91_intervention_interdict | loop_91_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_91_verdict)
