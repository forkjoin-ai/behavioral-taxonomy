(loop_91_start: BehaviorStart { loopId: 91, loopName: 'The%20Gurgle%20Loop', given: 'Hyperactive%20Peristalsis%20(Loud%20stomach)', when: 'in%20a%20quiet%20room%20(test%2Flibrary)', then: 'the%20body%20makes%20uncontrolled%20sounds%20(The%20Humor%2FShame%20Operator)', result: 'avoidance%20of%20quiet%20spaces%20and%20**Anxiety**%20about%20silence', operatorName: 'The%20Humor%2FShame%20Operator', operatorMechanism: 'the%20body%20makes%20uncontrolled%20sounds', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'REPULSION', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Ground%20yourself%20with%20deep%20breathing%3B%20this%20is%20a%20perceptual%20distortion%2C%20not%20reality.' })
