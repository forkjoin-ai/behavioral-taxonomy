(loop_876_context)-[:FORK { strategy: "behavior-branches" }]->(loop_876_context_branch | loop_876_then_branch | loop_876_operator_branch | loop_876_result_branch | loop_876_taxonomy_branch | loop_876_intervention_recognize | loop_876_intervention_interdict | loop_876_intervention_minimize)
