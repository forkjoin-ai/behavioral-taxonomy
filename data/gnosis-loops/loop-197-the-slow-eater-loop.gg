(loop_197_context_branch | loop_197_then_branch | loop_197_operator_branch | loop_197_result_branch | loop_197_taxonomy_branch | loop_197_intervention_recognize | loop_197_intervention_interdict | loop_197_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_197_verdict)
