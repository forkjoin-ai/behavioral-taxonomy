(loop_871_given_gate: BehaviorAssess { stage: 'given', text: 'Chronic%20pain%20causing%20momentary%20wincing' })
(loop_871_inactive: BehaviorTerminal { loopId: 871, loopName: 'The%20Grimace%20Loop' })
(loop_871_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
(loop_871_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
