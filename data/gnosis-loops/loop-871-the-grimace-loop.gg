// Topology
(loop_871_start)-[:PROCESS]->(loop_871_given_gate)
(loop_871_given_gate)-[:PROCESS { case: "ok" }]->(loop_871_when_gate)
(loop_871_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_871_inactive)
(loop_871_when_gate)-[:PROCESS { case: "ok" }]->(loop_871_context)
(loop_871_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_871_inactive)
(loop_871_context)-[:FORK { strategy: "behavior-branches" }]->(loop_871_context_branch | loop_871_then_branch | loop_871_operator_branch | loop_871_result_branch | loop_871_taxonomy_branch | loop_871_intervention_recognize | loop_871_intervention_interdict | loop_871_intervention_minimize)
(loop_871_context_branch | loop_871_then_branch | loop_871_operator_branch | loop_871_result_branch | loop_871_taxonomy_branch | loop_871_intervention_recognize | loop_871_intervention_interdict | loop_871_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_871_verdict)
(loop_871_inactive)-[:PROCESS]->(loop_871_sink)
