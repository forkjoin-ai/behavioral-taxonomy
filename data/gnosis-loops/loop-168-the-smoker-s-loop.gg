(loop_168_context)-[:FORK { strategy: "behavior-branches" }]->(loop_168_context_branch | loop_168_then_branch | loop_168_operator_branch | loop_168_result_branch | loop_168_taxonomy_branch | loop_168_intervention_recognize | loop_168_intervention_interdict | loop_168_intervention_minimize)
(loop_168_context_branch | loop_168_then_branch | loop_168_operator_branch | loop_168_result_branch | loop_168_taxonomy_branch | loop_168_intervention_recognize | loop_168_intervention_interdict | loop_168_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_168_verdict)
