(loop_339_inactive: BehaviorTerminal { loopId: 339, loopName: 'The%20Superman%20Loop' })
(loop_339_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22' })
