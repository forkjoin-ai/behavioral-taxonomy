(loop_339_inactive)-[:PROCESS]->(loop_339_sink)
(loop_339_verdict)-[:PROCESS]->(loop_339_sink)
(loop_339_intervention_recognize)-[:INTERFERE { mode: "destructive" }]->(loop_339_then_branch)
