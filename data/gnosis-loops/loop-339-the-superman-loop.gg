(loop_339_context)-[:FORK { strategy: "behavior-branches" }]->(loop_339_context_branch | loop_339_then_branch | loop_339_operator_branch | loop_339_result_branch | loop_339_taxonomy_branch | loop_339_intervention_recognize | loop_339_intervention_interdict | loop_339_intervention_minimize)
