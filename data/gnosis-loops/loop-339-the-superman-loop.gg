(loop_339_start: BehaviorStart { loopId: 339, loopName: 'The%20Superman%20Loop', given: 'Akimbo%20stance%20(elbows%20out)', when: 'standing', then: 'the%20body%20occupies%20maximum%20lateral%20space%20(The%20Authority%2FDominance%20Operator)', result: 'being%20perceived%20as%20%22In%20Charge%22%20or%20%22Bossy.%22', operatorName: 'The%20Authority%2FDominance%20Operator', operatorMechanism: 'the%20body%20occupies%20maximum%20lateral%20space', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_339_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_339_then_branch: BehaviorEmit { emission: 'then', text: 'the%20body%20occupies%20maximum%20lateral%20space%20(The%20Authority%2FDominance%20Operator)' })
(loop_339_verdict: BehaviorVerdict { loopId: 339, loopName: 'The%20Superman%20Loop', then: 'the%20body%20occupies%20maximum%20lateral%20space%20(The%20Authority%2FDominance%20Operator)', result: 'being%20perceived%20as%20%22In%20Charge%22%20or%20%22Bossy.%22', operatorName: 'The%20Authority%2FDominance%20Operator', operatorMechanism: 'the%20body%20occupies%20maximum%20lateral%20space', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
