(loop_548_verdict: BehaviorVerdict { loopId: 548, loopName: 'The%20Wide%20Base%20Loop', then: 'it%20triggers%20%22Ruggedness%22%20or%20%22Ethnic%20Othering%22%20(The%20Exotic%20Operator)', result: 'specific%20typecasting%20in%20media%20and%20social%20expectations%20of%20%22toughness.%22', operatorName: 'The%20Exotic%20Operator', operatorMechanism: 'it%20triggers%20%22Ruggedness%22%20or%20%22Ethnic%20Othering%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
