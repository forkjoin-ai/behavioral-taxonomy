(loop_548_start: BehaviorStart { loopId: 548, loopName: 'The%20Wide%20Base%20Loop', given: 'Broad%20nasal%20base', when: 'in%20a%20Eurocentric%20beauty%20standard%20context', then: 'it%20triggers%20%22Ruggedness%22%20or%20%22Ethnic%20Othering%22%20(The%20Exotic%20Operator)', result: 'specific%20typecasting%20in%20media%20and%20social%20expectations%20of%20%22toughness.%22', operatorName: 'The%20Exotic%20Operator', operatorMechanism: 'it%20triggers%20%22Ruggedness%22%20or%20%22Ethnic%20Othering%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
