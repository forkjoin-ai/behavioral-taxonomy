(loop_548_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_548_inactive)
(loop_548_context)-[:FORK { strategy: "behavior-branches" }]->(loop_548_context_branch | loop_548_then_branch | loop_548_operator_branch | loop_548_result_branch | loop_548_taxonomy_branch | loop_548_intervention_recognize | loop_548_intervention_interdict | loop_548_intervention_minimize)
(loop_548_context_branch | loop_548_then_branch | loop_548_operator_branch | loop_548_result_branch | loop_548_taxonomy_branch | loop_548_intervention_recognize | loop_548_intervention_interdict | loop_548_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_548_verdict)
