(loop_443_context_branch | loop_443_then_branch | loop_443_operator_branch | loop_443_result_branch | loop_443_taxonomy_branch | loop_443_intervention_recognize | loop_443_intervention_interdict | loop_443_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_443_verdict)
