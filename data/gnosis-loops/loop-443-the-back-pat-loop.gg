(loop_443_start: BehaviorStart { loopId: 443, loopName: 'The%20Back%20Pat%20Loop', given: 'Patting%20others%20on%20the%20back%2Fshoulder', when: 'greeting%20a%20peer', then: 'it%20signals%20%22Dominance%22%20or%20%22Patronage%22%20(The%20Superior%20Operator)', result: 'the%20recipient%20feeling%20%22Small%22%20or%20%22Managed.%22', operatorName: 'The%20Superior%20Operator', operatorMechanism: 'it%20signals%20%22Dominance%22%20or%20%22Patronage%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
