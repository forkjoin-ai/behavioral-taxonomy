(loop_1033_sink: BehaviorSink)
(loop_1033_start: BehaviorStart { loopId: 1033, loopName: 'The%20Main%20Character%20Loop', given: 'Solipsistic%20worldview', when: 'walking%20down%20the%20street%20with%20headphones', then: 'the%20gait%20synchronizes%20to%20the%20music%20(The%20Movie%20Scene)', result: 'a%20%22performative%22%20walk%20that%20assumes%20an%20invisible%20audience', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20gait%20synchronizes%20to%20the%20music%20(The%20Movie%20Scene)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_1033_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1033_then_branch: BehaviorEmit { emission: 'then', text: 'the%20gait%20synchronizes%20to%20the%20music%20(The%20Movie%20Scene)' })
(loop_1033_verdict: BehaviorVerdict { loopId: 1033, loopName: 'The%20Main%20Character%20Loop', then: 'the%20gait%20synchronizes%20to%20the%20music%20(The%20Movie%20Scene)', result: 'a%20%22performative%22%20walk%20that%20assumes%20an%20invisible%20audience', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20gait%20synchronizes%20to%20the%20music%20(The%20Movie%20Scene)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1033_when_gate: BehaviorAssess { stage: 'when', text: 'walking%20down%20the%20street%20with%20headphones' })

// Topology
(loop_1033_start)-[:PROCESS]->(loop_1033_given_gate)
(loop_1033_given_gate)-[:PROCESS { case: "ok" }]->(loop_1033_when_gate)
