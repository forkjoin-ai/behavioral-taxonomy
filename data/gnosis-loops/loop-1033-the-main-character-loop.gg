(loop_1033_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1033_context_branch | loop_1033_then_branch | loop_1033_operator_branch | loop_1033_result_branch | loop_1033_taxonomy_branch | loop_1033_intervention_recognize | loop_1033_intervention_interdict | loop_1033_intervention_minimize)
(loop_1033_context_branch | loop_1033_then_branch | loop_1033_operator_branch | loop_1033_result_branch | loop_1033_taxonomy_branch | loop_1033_intervention_recognize | loop_1033_intervention_interdict | loop_1033_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1033_verdict)
(loop_1033_inactive)-[:PROCESS]->(loop_1033_sink)
