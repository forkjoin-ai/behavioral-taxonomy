(loop_833_start: BehaviorStart { loopId: 833, loopName: 'The%20Laser%20Loop', given: 'Extremely%20low%20blink%20rate%20%2B%20foveal%20fixation', when: 'listening%20to%20someone', then: 'the%20gaze%20feels%20%22Predatory%22%20or%20%22Hypnotic%22%20(The%20Cult%20Leader%20Operator)', result: 'the%20speaker%20feeling%20exposed%20and%20revealing%20more%20truth%20than%20intended', operatorName: 'The%20Cult%20Leader%20Operator', operatorMechanism: 'the%20gaze%20feels%20%22Predatory%22%20or%20%22Hypnotic%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
