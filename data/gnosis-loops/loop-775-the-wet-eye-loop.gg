// behavioral-loop-775.gg
// Executable Gnosis projection for The Wet Eye Loop.

// Nodes
(loop_775_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_775_context_branch: BehaviorEmit { emission: 'context' })
