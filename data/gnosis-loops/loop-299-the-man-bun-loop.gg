(loop_299_context_branch | loop_299_then_branch | loop_299_operator_branch | loop_299_result_branch | loop_299_taxonomy_branch | loop_299_intervention_recognize | loop_299_intervention_interdict | loop_299_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_299_verdict)
