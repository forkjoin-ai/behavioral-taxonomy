(loop_861_given_gate: BehaviorAssess { stage: 'given', text: 'Springy%2C%20high-energy%20step' })
(loop_861_inactive: BehaviorTerminal { loopId: 861, loopName: 'The%20Bounce%20Loop' })
(loop_861_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations' })
(loop_861_intervention_minimize: BehaviorEmit { emission: 'intervention', interventionKind: 'minimize', text: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_861_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong' })
