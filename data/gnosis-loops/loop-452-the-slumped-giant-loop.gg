// Topology
(loop_452_start)-[:PROCESS]->(loop_452_given_gate)
(loop_452_given_gate)-[:PROCESS { case: "ok" }]->(loop_452_when_gate)
(loop_452_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_452_inactive)
(loop_452_when_gate)-[:PROCESS { case: "ok" }]->(loop_452_context)
(loop_452_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_452_inactive)
(loop_452_context)-[:FORK { strategy: "behavior-branches" }]->(loop_452_context_branch | loop_452_then_branch | loop_452_operator_branch | loop_452_result_branch | loop_452_taxonomy_branch | loop_452_intervention_recognize | loop_452_intervention_leverage)
(loop_452_context_branch | loop_452_then_branch | loop_452_operator_branch | loop_452_result_branch | loop_452_taxonomy_branch | loop_452_intervention_recognize | loop_452_intervention_leverage)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_452_verdict)
(loop_452_inactive)-[:PROCESS]->(loop_452_sink)
(loop_452_verdict)-[:PROCESS]->(loop_452_sink)
(loop_452_verdict)-[:MEASURE]->(loop_452_sink)
(loop_452_intervention_recognize)-[:PROCESS { mode: "destructive", role: "intervention-sliver" }]->(loop_452_then_branch)
(loop_452_intervention_leverage)-[:PROCESS { mode: "constructive", role: "intervention-sliver" }]->(loop_452_result_branch)