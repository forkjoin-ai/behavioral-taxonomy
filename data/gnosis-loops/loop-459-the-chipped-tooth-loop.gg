// behavioral-loop-459.gg
// Executable Gnosis projection for The Chipped Tooth Loop.

// Nodes
(loop_459_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_459_context_branch: BehaviorEmit { emission: 'context' })
(loop_459_given_gate: BehaviorAssess { stage: 'given', text: 'Fractured%20incisor%20(untreated)' })
(loop_459_inactive: BehaviorTerminal { loopId: 459, loopName: 'The%20Chipped%20Tooth%20Loop' })
