(loop_459_intervention_recognize: BehaviorEmit { emission: 'intervention', interventionKind: 'recognize', text: 'Watch%20for%20snap%20judgments%20based%20on%20appearance' })
(loop_459_operator_branch: BehaviorEmit { emission: 'operator', name: 'The%20Broken%20Window%20Operator', mechanism: 'it%20signals%20%22Roughness%2C%22%20%22Poverty%2C%22%20or%20%22Carelessness%22' })
