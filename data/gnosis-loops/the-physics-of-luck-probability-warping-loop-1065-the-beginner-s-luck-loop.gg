(loop_1065_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1065_context_branch | loop_1065_then_branch | loop_1065_operator_branch | loop_1065_result_branch | loop_1065_taxonomy_branch | loop_1065_intervention_recognize | loop_1065_intervention_interdict | loop_1065_intervention_minimize)
(loop_1065_context_branch | loop_1065_then_branch | loop_1065_operator_branch | loop_1065_result_branch | loop_1065_taxonomy_branch | loop_1065_intervention_recognize | loop_1065_intervention_interdict | loop_1065_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1065_verdict)
