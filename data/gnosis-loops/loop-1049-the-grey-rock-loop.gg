// Topology
(loop_1049_start)-[:PROCESS]->(loop_1049_given_gate)
(loop_1049_given_gate)-[:PROCESS { case: "ok" }]->(loop_1049_when_gate)
(loop_1049_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_1049_inactive)
