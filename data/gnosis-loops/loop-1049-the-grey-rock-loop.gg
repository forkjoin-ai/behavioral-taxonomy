(loop_1049_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1049_context_branch | loop_1049_then_branch | loop_1049_operator_branch | loop_1049_result_branch | loop_1049_taxonomy_branch | loop_1049_intervention_recognize | loop_1049_intervention_interdict | loop_1049_intervention_minimize)
(loop_1049_context_branch | loop_1049_then_branch | loop_1049_operator_branch | loop_1049_result_branch | loop_1049_taxonomy_branch | loop_1049_intervention_recognize | loop_1049_intervention_interdict | loop_1049_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1049_verdict)
(loop_1049_inactive)-[:PROCESS]->(loop_1049_sink)
