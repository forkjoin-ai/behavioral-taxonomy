(loop_325_start: BehaviorStart { loopId: 325, loopName: 'The%20Heavy%20Breather%20Loop', given: 'Obesity%2C%20asthma%2C%20or%20deviated%20septum', when: 'sitting%20in%20a%20quiet%20meeting', then: 'the%20audible%20respiration%20signals%20%22Exertion%22%20or%20%22Unhealth%22%20(The%20Mortality%20Operator)', result: 'colleagues%20perceiving%20the%20individual%20as%20%22Struggling%22%20to%20merely%20exist', operatorName: 'The%20Mortality%20Operator', operatorMechanism: 'the%20audible%20respiration%20signals%20%22Exertion%22%20or%20%22Unhealth%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_325_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
