(loop_325_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_325_inactive)
(loop_325_context)-[:FORK { strategy: "behavior-branches" }]->(loop_325_context_branch | loop_325_then_branch | loop_325_operator_branch | loop_325_result_branch | loop_325_taxonomy_branch | loop_325_intervention_recognize | loop_325_intervention_interdict | loop_325_intervention_minimize)
(loop_325_context_branch | loop_325_then_branch | loop_325_operator_branch | loop_325_result_branch | loop_325_taxonomy_branch | loop_325_intervention_recognize | loop_325_intervention_interdict | loop_325_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_325_verdict)
(loop_325_inactive)-[:PROCESS]->(loop_325_sink)
