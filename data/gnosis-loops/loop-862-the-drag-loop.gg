(loop_862_context_branch | loop_862_then_branch | loop_862_operator_branch | loop_862_result_branch | loop_862_taxonomy_branch | loop_862_intervention_recognize | loop_862_intervention_interdict | loop_862_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_862_verdict)
