(loop_2601_context)-[:FORK { strategy: "behavior-branches" }]->(loop_2601_context_branch | loop_2601_then_branch | loop_2601_operator_branch | loop_2601_result_branch | loop_2601_taxonomy_branch | loop_2601_intervention_recognize | loop_2601_intervention_interdict | loop_2601_intervention_minimize)
