// Topology
(loop_461_start)-[:PROCESS]->(loop_461_given_gate)
(loop_461_given_gate)-[:PROCESS { case: "ok" }]->(loop_461_when_gate)
(loop_461_given_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_461_inactive)
