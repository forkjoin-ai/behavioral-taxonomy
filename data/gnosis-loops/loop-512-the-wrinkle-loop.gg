(loop_512_start: BehaviorStart { loopId: 512, loopName: 'The%20Wrinkle%20Loop', given: 'Linen%2FCotton%20crushed%20from%20travel', when: 'meeting%20a%20client', then: 'it%20signals%20%22Disorganized%22%20or%20%22Slept%20in%20clothes%22%20(The%20Messy%20Operator)', result: 'lowered%20expectations%20of%20work%20precision', operatorName: 'The%20Messy%20Operator', operatorMechanism: 'it%20signals%20%22Disorganized%22%20or%20%22Slept%20in%20clothes%22', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Use%20grounding%20techniques%20to%20avoid%20emotional%20hijacking' })
