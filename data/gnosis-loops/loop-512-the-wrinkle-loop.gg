(loop_512_context)-[:FORK { strategy: "behavior-branches" }]->(loop_512_context_branch | loop_512_then_branch | loop_512_operator_branch | loop_512_result_branch | loop_512_taxonomy_branch | loop_512_intervention_recognize | loop_512_intervention_interdict | loop_512_intervention_minimize)
(loop_512_context_branch | loop_512_then_branch | loop_512_operator_branch | loop_512_result_branch | loop_512_taxonomy_branch | loop_512_intervention_recognize | loop_512_intervention_interdict | loop_512_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_512_verdict)
(loop_512_inactive)-[:PROCESS]->(loop_512_sink)
