// behavioral-loop-388.gg
// Executable Gnosis projection for The Wide Hips Loop.

// Nodes
(loop_388_context: Destructure { from: 'value', fields: 'context,loop' })
(loop_388_context_branch: BehaviorEmit { emission: 'context' })
(loop_388_given_gate: BehaviorAssess { stage: 'given', text: 'Pelvic%20width%20exceeding%20shoulder%20width%20(Gynecoid%20pelvis%20in%20male)' })
(loop_388_inactive: BehaviorTerminal { loopId: 388, loopName: 'The%20Wide%20Hips%20Loop' })
