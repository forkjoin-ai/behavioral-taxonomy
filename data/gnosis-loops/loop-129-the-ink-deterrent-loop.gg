(loop_129_context_branch | loop_129_then_branch | loop_129_operator_branch | loop_129_result_branch | loop_129_taxonomy_branch | loop_129_intervention_recognize | loop_129_intervention_interdict | loop_129_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_129_verdict)
