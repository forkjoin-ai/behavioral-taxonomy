(loop_10001_sink: BehaviorSink)
(loop_10001_start: BehaviorStart { loopId: 10001, loopName: 'The%20Love%20Bombing%20Loop', given: 'A%20new%20target%2Fvictim%20with%20high%20empathy%20or%20vulnerability', when: 'The%20relationship%20begins%20(Day%200%20-%20Day%2090)', then: 'Subject%20overwhelms%20target%20with%20excessive%20praise%2C%20gifts%2C%20and%20communication', result: 'Target%20becomes%20chemically%20addicted%20to%20the%20validation%3B%20Subject%20secures%20control%20before%20dropping%20the%20mask', operatorName: 'Unknown%20Operator', operatorMechanism: 'Unknown%20mechanism', origin: 'BEHAVIORAL', modality: 'META', mutability: 'FLUID', valences: 'SUBMISSION', interventionDifficulty: '5', intervention_recognize: 'Pay%20attention%20to%20body%20language%20shifts', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
(loop_10001_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'META', mutability: 'FLUID', valences: 'SUBMISSION' })
(loop_10001_then_branch: BehaviorEmit { emission: 'then', text: 'Subject%20overwhelms%20target%20with%20excessive%20praise%2C%20gifts%2C%20and%20communication' })
(loop_10001_verdict: BehaviorVerdict { loopId: 10001, loopName: 'The%20Love%20Bombing%20Loop', then: 'Subject%20overwhelms%20target%20with%20excessive%20praise%2C%20gifts%2C%20and%20communication', result: 'Target%20becomes%20chemically%20addicted%20to%20the%20validation%3B%20Subject%20secures%20control%20before%20dropping%20the%20mask', operatorName: 'Unknown%20Operator', operatorMechanism: 'Unknown%20mechanism', origin: 'BEHAVIORAL', modality: 'META', mutability: 'FLUID', valences: 'SUBMISSION' })
(loop_10001_when_gate: BehaviorAssess { stage: 'when', text: 'The%20relationship%20begins%20(Day%200%20-%20Day%2090)' })

// Topology
(loop_10001_start)-[:PROCESS]->(loop_10001_given_gate)
(loop_10001_given_gate)-[:PROCESS { case: "ok" }]->(loop_10001_when_gate)
(loop_10001_given_gate)-[:PROCESS { case: "err" }]->(loop_10001_inactive)
(loop_10001_when_gate)-[:PROCESS { case: "ok" }]->(loop_10001_context)
(loop_10001_when_gate)-[:PROCESS { case: "err" }]->(loop_10001_inactive)
(loop_10001_context)-[:FORK { strategy: "behavior-branches" }]->(loop_10001_context_branch | loop_10001_then_branch | loop_10001_operator_branch | loop_10001_result_branch | loop_10001_taxonomy_branch | loop_10001_intervention_recognize | loop_10001_intervention_interdict | loop_10001_intervention_minimize)
(loop_10001_context_branch | loop_10001_then_branch | loop_10001_operator_branch | loop_10001_result_branch | loop_10001_taxonomy_branch | loop_10001_intervention_recognize | loop_10001_intervention_interdict | loop_10001_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_10001_verdict)
(loop_10001_inactive)-[:PROCESS]->(loop_10001_sink)
