(loop_1071_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1071_context_branch | loop_1071_then_branch | loop_1071_operator_branch | loop_1071_result_branch | loop_1071_taxonomy_branch | loop_1071_intervention_recognize | loop_1071_intervention_interdict | loop_1071_intervention_minimize)
(loop_1071_context_branch | loop_1071_then_branch | loop_1071_operator_branch | loop_1071_result_branch | loop_1071_taxonomy_branch | loop_1071_intervention_recognize | loop_1071_intervention_interdict | loop_1071_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1071_verdict)
(loop_1071_inactive)-[:PROCESS]->(loop_1071_sink)
(loop_1071_verdict)-[:PROCESS]->(loop_1071_sink)
