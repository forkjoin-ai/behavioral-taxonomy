(loop_1010_when_gate)-[:PROCESS { case: "err" }]->(loop_1010_inactive)
(loop_1010_context)-[:FORK { strategy: "behavior-branches" }]->(loop_1010_context_branch | loop_1010_then_branch | loop_1010_operator_branch | loop_1010_result_branch | loop_1010_taxonomy_branch | loop_1010_intervention_recognize | loop_1010_intervention_interdict | loop_1010_intervention_minimize)
(loop_1010_context_branch | loop_1010_then_branch | loop_1010_operator_branch | loop_1010_result_branch | loop_1010_taxonomy_branch | loop_1010_intervention_recognize | loop_1010_intervention_interdict | loop_1010_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1010_verdict)
(loop_1010_inactive)-[:PROCESS]->(loop_1010_sink)
(loop_1010_verdict)-[:PROCESS]->(loop_1010_sink)
