(loop_1010_start: BehaviorStart { loopId: 1010, loopName: 'The%20Dead%20Still%20Loop', given: 'Complete%20lack%20of%20fidgeting%20or%20swaying', when: 'chaos%20erupts', then: 'the%20individual%20remains%20a%20statue%20(The%20Sniper%20Operator)', result: "becoming%20the%20anchor%20point%20for%20the%20room's%20panic", operatorName: 'The%20Sniper%20Operator', operatorMechanism: 'the%20individual%20remains%20a%20statue', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '5', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22', intervention_minimize: 'Prepare%20counter-narratives%20in%20advance%20for%20recurring%20situations' })
(loop_1010_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1010_then_branch: BehaviorEmit { emission: 'then', text: 'the%20individual%20remains%20a%20statue%20(The%20Sniper%20Operator)' })
(loop_1010_verdict: BehaviorVerdict { loopId: 1010, loopName: 'The%20Dead%20Still%20Loop', then: 'the%20individual%20remains%20a%20statue%20(The%20Sniper%20Operator)', result: "becoming%20the%20anchor%20point%20for%20the%20room's%20panic", operatorName: 'The%20Sniper%20Operator', operatorMechanism: 'the%20individual%20remains%20a%20statue', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
(loop_1010_when_gate: BehaviorAssess { stage: 'when', text: 'chaos%20erupts' })

// Topology
(loop_1010_start)-[:PROCESS]->(loop_1010_given_gate)
(loop_1010_given_gate)-[:PROCESS { case: "ok" }]->(loop_1010_when_gate)
(loop_1010_given_gate)-[:PROCESS { case: "err" }]->(loop_1010_inactive)
