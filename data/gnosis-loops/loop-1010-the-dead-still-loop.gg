(loop_1010_inactive: BehaviorTerminal { loopId: 1010, loopName: 'The%20Dead%20Still%20Loop' })
(loop_1010_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Use%20implementation%20intentions%3A%20%22When%20X%20happens%2C%20I%20will%20do%20Y%22' })
