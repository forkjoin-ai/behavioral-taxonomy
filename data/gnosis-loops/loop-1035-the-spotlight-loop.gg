(loop_1035_start: BehaviorStart { loopId: 1035, loopName: 'The%20Spotlight%20Loop', given: 'Hyper-self-consciousness', when: 'a%20minor%20mistake%20happens%20(tripping)', then: 'the%20individual%20believes%20*everyone*%20saw%20it%20(The%20Stage%20Light)', result: 'extreme%20shame%20for%20an%20event%20nobody%20noticed', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20individual%20believes%20*everyone*%20saw%20it%20(The%20Stage%20Light)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '6', intervention_recognize: 'Watch%20for%20snap%20judgments%20based%20on%20appearance', intervention_interdict: 'Build%20awareness%20through%20journaling%20or%20recording', intervention_minimize: 'Reframe%20the%20situation%3A%20what%20would%20an%20objective%20observer%20see%3F' })
(loop_1035_taxonomy_branch: BehaviorEmit { emission: 'taxonomy', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
