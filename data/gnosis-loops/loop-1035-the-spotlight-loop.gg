(loop_1035_verdict: BehaviorVerdict { loopId: 1035, loopName: 'The%20Spotlight%20Loop', then: 'the%20individual%20believes%20*everyone*%20saw%20it%20(The%20Stage%20Light)', result: 'extreme%20shame%20for%20an%20event%20nobody%20noticed', operatorName: 'Unknown%20Operator', operatorMechanism: 'the%20individual%20believes%20*everyone*%20saw%20it%20(The%20Stage%20Light)', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION' })
