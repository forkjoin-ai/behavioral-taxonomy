(loop_1035_context_branch | loop_1035_then_branch | loop_1035_operator_branch | loop_1035_result_branch | loop_1035_taxonomy_branch | loop_1035_intervention_recognize | loop_1035_intervention_interdict | loop_1035_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_1035_verdict)
