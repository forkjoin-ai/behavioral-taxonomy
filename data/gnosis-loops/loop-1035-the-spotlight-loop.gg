(loop_1035_inactive: BehaviorTerminal { loopId: 1035, loopName: 'The%20Spotlight%20Loop' })
(loop_1035_intervention_interdict: BehaviorEmit { emission: 'intervention', interventionKind: 'interdict', text: 'Build%20awareness%20through%20journaling%20or%20recording' })
