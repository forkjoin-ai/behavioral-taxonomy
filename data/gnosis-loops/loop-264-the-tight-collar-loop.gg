(loop_264_context)-[:FORK { strategy: "behavior-branches" }]->(loop_264_context_branch | loop_264_then_branch | loop_264_operator_branch | loop_264_result_branch | loop_264_taxonomy_branch | loop_264_intervention_recognize | loop_264_intervention_interdict | loop_264_intervention_minimize)
(loop_264_context_branch | loop_264_then_branch | loop_264_operator_branch | loop_264_result_branch | loop_264_taxonomy_branch | loop_264_intervention_recognize | loop_264_intervention_interdict | loop_264_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_264_verdict)
(loop_264_inactive)-[:PROCESS]->(loop_264_sink)
