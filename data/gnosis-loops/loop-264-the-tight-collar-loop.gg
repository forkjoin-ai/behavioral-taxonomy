(loop_264_start: BehaviorStart { loopId: 264, loopName: 'The%20Tight%20Collar%20Loop', given: 'Neck%20circumference%20%3E%2017%20inches', when: 'wearing%20a%20tie', then: 'the%20face%20flushes%20red%20due%20to%20restriction%20(The%20Strangled%20Operator)', result: 'the%20individual%20looking%20%22Stressed%22%20or%20%22Angry%22%20even%20when%20calm', operatorName: 'The%20Strangled%20Operator', operatorMechanism: 'the%20face%20flushes%20red%20due%20to%20restriction', origin: 'BEHAVIORAL', modality: 'VISUAL_STATIC', mutability: '1', valences: 'SUBMISSION', interventionDifficulty: '7', intervention_recognize: 'Notice%20when%20first%20impressions%20feel%20unusually%20strong', intervention_interdict: 'Practice%20deliberate%20counter-behaviors%20in%20low-stakes%20situations', intervention_minimize: 'Recognize%20the%20loop%20is%20triggering%20and%20pause%20before%20reacting' })
