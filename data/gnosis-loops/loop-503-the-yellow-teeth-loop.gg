(loop_503_when_gate)-[:VENT { case: "err", condition: "corridor-reject" }]->(loop_503_inactive)
(loop_503_context)-[:FORK { strategy: "behavior-branches" }]->(loop_503_context_branch | loop_503_then_branch | loop_503_operator_branch | loop_503_result_branch | loop_503_taxonomy_branch | loop_503_intervention_recognize | loop_503_intervention_interdict | loop_503_intervention_minimize)
(loop_503_context_branch | loop_503_then_branch | loop_503_operator_branch | loop_503_result_branch | loop_503_taxonomy_branch | loop_503_intervention_recognize | loop_503_intervention_interdict | loop_503_intervention_minimize)-[:FOLD { strategy: "behavior-synthesis" }]->(loop_503_verdict)
(loop_503_inactive)-[:PROCESS]->(loop_503_sink)
(loop_503_verdict)-[:PROCESS]->(loop_503_sink)
(loop_503_verdict)-[:MEASURE]->(loop_503_sink)
